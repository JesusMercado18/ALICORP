                                                OnSelect: "=UpdateContext({varMesFinSelected : ThisItem , varOpenDropDownMesFin: false, varDiaFinSelected: Blank()});\nIf(Value(varMesFinSelected.ID) < Value(varMesInicioSelected.ID),\n    UpdateContext({CloseAlertSpvNuevoComunicado:true, SpvNvCmcMensajeError: \"Debes ingresar un mes mayor al Mes Inicio\"});\n    UpdateContext({varMesFinSelected: Blank()})\n);\nIf(\n    // 1. Si el campo de mes está vacío (Recurrencia Mensual), volvemos a los 31 días\n    IsBlank(varMesFinSelected.ID),\n    ClearCollect(colSpvNvCmcDiasFin, Sequence(31)),\n    \n    // 2. Si hay un mes seleccionado (Recurrencia Anual), calculamos sus días exactos\n    With(\n        {\n            // Evaluamos si el mes seleccionado ya pasó este año. \n            // Si ya pasó, calculamos con base en el año siguiente (clave para saber si el próximo febrero será bisiesto)\n            AnoEvaluacion: If(\n                varMesFinSelected.ID < Month(Today()),\n                Year(Today()) + 1,\n                Year(Today())\n            )\n        },\n        With(\n            {\n                // Usamos el \"truco\" del día 1 del mes siguiente menos 1 día\n                TopeDias: Day(DateAdd(Date(AnoEvaluacion, varMesFinSelected.ID + 1, 1), -1, TimeUnit.Days))\n            },\n            // Actualizamos la colección de días con la cantidad exacta (ej. Sequence(28))\n            ClearCollect(colSpvNvCmcDiasFin, Sequence(TopeDias))\n        )\n    )\n)"
