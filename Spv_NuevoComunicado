                                                OnSelect: "=// 1. Igualación de fechas si el fin está en blanco\nIf(\n    IsBlank(var_RangeDatePicker_DateEnd),\n    UpdateContext({var_RangeDatePicker_DateEnd: var_RangeDatePicker_DateStart})\n);\n\n// 2. Bloque de validación secuencial\nIf(\n    IsBlank(SpvNvCmc_TxtITituloFormulario.Text),\n        UpdateContext({CloseAlertSpvNuevoComunicado:true, SpvNvCmcMensajeError: \"Debes ingresar el Título\"}),\n    \n    IsBlank(First(SpvNvCmc_var_uploadFile_listeAttachment)),\n        UpdateContext({CloseAlertSpvNuevoComunicado:true, SpvNvCmcMensajeError: \"Debes ingresar el Banner\"}),\n    \n    SpvNvCmc_LblFechaSeleccionada.Text = \"Tiempo de duración\" && IsEmpty(colEstadoRecurrenteSeleccionadas),\n        UpdateContext({CloseAlertSpvNuevoComunicado:true, SpvNvCmcMensajeError: \"Debes ingresar el Tiempo de duración\"}),\n    \n    IsBlank(SpvNvCmc_LblDirigidoSel.Value),\n        UpdateContext({CloseAlertSpvNuevoComunicado:true, SpvNvCmcMensajeError: \"Debes seleccionar el Dirigido a\"}),\n    \n    // \U0001F539 CORRECCIÓN: Se ignora si el valor principal es \"Todos\"\n    SpvNvCmc_LblDirigidoSel.Value <> \"Todos\" && IsBlank(SpvNvCmc_LblDirigidoOpcionSel.Value),\n        UpdateContext({CloseAlertSpvNuevoComunicado:true, SpvNvCmcMensajeError: If(SpvNvCmc_LblDirigidoSel.Value=\"Gerencia\",\"Debes seleccionar la Gerencia\",\"Debes seleccionar el País\")}),\n    \n    (!IsEmpty(colEstadoRecurrenteSeleccionadas) && IsBlank(varDiaInicioSelected.Value)),\n        UpdateContext({CloseAlertSpvNuevoComunicado:true, SpvNvCmcMensajeError: \"Debes ingresar el Día Inicio\"}),\n    \n    (!IsEmpty(colEstadoRecurrenteSeleccionadas) && IsBlank(varDiaFinSelected.Value)),\n        UpdateContext({CloseAlertSpvNuevoComunicado:true, SpvNvCmcMensajeError: \"Debes ingresar el Día Fin\"}),\n    \n    (!IsBlank(SpvNvCmc_LblMesInicio.Value) && IsBlank(SpvNvCmc_LblMesFin.Value)),\n        UpdateContext({CloseAlertSpvNuevoComunicado:true, SpvNvCmcMensajeError: \"Debes ingresar el Mes Fin\"}),\n    \n    IsBlank(SpvNvCmc_TxtIDescripcion.Text),\n        UpdateContext({CloseAlertSpvNuevoComunicado:true, SpvNvCmcMensajeError: \"Debes ingresar la Descripción\"}),\n    \n    // 3. \U0001F539 BLOQUE DE GUARDADO (Ejecutado solo si no aplican los errores anteriores)\n    IfError(\n        Patch(\n            'LCP-001_List_Comunicados',\n            Defaults('LCP-001_List_Comunicados'),\n            {\n                // Mapeo directo de Gerencia y País aplicando la palabra \"Todos\"\n                Gerencia: If(SpvNvCmc_LblDirigidoSel.Value = \"Todos\", \"Todos\", If(SpvNvCmc_LblDirigidoSel.Value = \"Gerencia\", Text(varTextoSeleccionado), Blank())),\n                Pais: If(SpvNvCmc_LblDirigidoSel.Value = \"Todos\", \"Todos\", If(SpvNvCmc_LblDirigidoSel.Value = \"País\", Text(varTextoSeleccionado), Blank())),\n                \n                Cabecera: SpvNvCmc_TxtITituloFormulario.Text,\n                Cuerpo: SpvNvCmc_TxtIDescripcion.Text,\n                UsuarioCreador: User().FullName,\n                FechaCreacion: Now(),\n                Estado: \"Vigente\",\n                FechaInicio: var_RangeDatePicker_DateStart,\n                FechaFin: var_RangeDatePicker_DateEnd,\n                DiaInicio: Text(varDiaInicioSelected.Value),\n                MesInicio: Text(varMesInicioSelected.ID),\n                DiaFin: Text(varDiaFinSelected.Value),\n                MesFin: Text(varMesFinSelected.ID),\n                EstadoComunicado: \"Activo\",\n                Recurrente: CountRows(colEstadoRecurrenteSeleccionadas) > 0,\n                TipoRecurrente: First(colEstadoRecurrenteSeleccionadas).Value,\n                Imagen: If(\n                    !IsEmpty(SpvNvCmc_var_uploadFile_listeAttachment),\n                    {\n                        FileName: First(SpvNvCmc_var_uploadFile_listeAttachment).nombre,\n                        Value: First(SpvNvCmc_var_uploadFile_listeAttachment).VistaPrevia,\n                        Full: Blank(),\n                        Large: Blank(),\n                        Medium: Blank(),\n                        Small: Blank(),\n                        Id: Blank(),\n                        MetaData: Blank()\n                    },\n                    Blank()\n                )\n            }\n        ),\n        // \U0001F534 Manejador de Error del Patch\n        UpdateContext({\n            CloseAlertSpvNuevoComunicado: true,\n            SpvNvCmcMensajeError: \"Ocurrió un error al crear la comunicación\"\n        }),\n        \n        // \U0001F7E2 Manejador de Éxito del Patch\n        Set(SpvNvCmcAlertaSatisfaccion, true);\n        Set(Var_SpvMensajeSatisfactorioComunicacion, \"Se ha creado una nueva comunicación.\");\n        Reset(SpvNvCmc_TxtITituloFormulario);\n        UpdateContext({var_RangeDatePicker_DateStart: Blank(), var_RangeDatePicker_DateEnd: Blank()});\n        Reset(SpvNvCmc_LblDirigidoSel);\n        Remove(SpvNvCmc_var_uploadFile_listeAttachment, First(SpvNvCmc_var_uploadFile_listeAttachment));\n        Reset(SpvNvCmc_TxtIDescripcion);\n        UpdateContext({varTextoSeleccionado : Blank()});\n        Navigate(Spv_Comunicados)\n    )\n)"
