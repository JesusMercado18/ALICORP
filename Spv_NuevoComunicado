                                                            DisplayMode: =If(Self.MaxAttachments = CountRows(SpvNvCmc_Glrfiles.AllItems),DisplayMode.View,DisplayMode.Edit)
                                                            DropTargetBorderStyle: =BorderStyle.None
                                                            DropTargetBorderThickness: =0
                                                            Fill: =ColorValue(Var_ColorFondoAdjuntos)
                                                            FocusedBorderColor: =Blank()
                                                            Font: =Font.'Open Sans'
                                                            Height: |-
                                                              =//70
                                                              Parent.Height + 70
                                                            HoverColor: =ColorValue(Var_ColorFondoAdjuntos)
                                                            HoverFill: =ColorFade(ColorValue(Var_ColorFondoAdjuntos),20%)
                                                            ItemColor: =RGBA(0, 0, 0, 1)
                                                            ItemDisabledColor: =Blank()
                                                            ItemDisabledFill: =Blank()
                                                            ItemErrorColor: =Blank()
                                                            ItemErrorFill: =Blank()
                                                            ItemFill: =RGBA(0, 120, 212, 1)
                                                            ItemHoverColor: =RGBA(50, 49, 48, 1)
                                                            ItemHoverFill: =RGBA(245, 245, 245, 1)
                                                            ItemPressedColor: =Blank()
                                                            ItemPressedFill: =Blank()
                                                            ItemSpacing: =12
                                                            Items: =Blank()
                                                            MaxAttachments: =5
                                                            MaxAttachmentsText: ="Se alcanzo el máximo de archivos"
                                                            NoAttachmentsColor: =RGBA(161, 159, 157, 1)
                                                            NoAttachmentsText: =
                                                            OnAddFile: |-
                                                              =// 1️⃣ Establecer el límite máximo estricto a 25 MB en bytes
                                                              Set(
                                                                  SpvNvCmc_varLimiteBytes,
                                                                  25 * 1024 * 1024
                                                              );

                                                              // 2️⃣ Limpiar los errores anteriores
                                                              Clear(SpvNvCmc_colErroresAdjuntos);

                                                              // 3️⃣ Recorrer los archivos que el usuario acaba de adjuntar
                                                              ForAll(
                                                                  Self.Attachments As Fila,

                                                                  // Verificar que el archivo no esté duplicado
                                                                  If(
                                                                      IsBlank(
                                                                          LookUp(
                                                                              SpvNvCmc_var_uploadFile_listeAttachment As A,
                                                                              A.nombre = Fila.Name
                                                                          )
                                                                      ),

                                                                      With(
                                                                          {
                                                                              // Extraer la extensión del archivo
                                                                              extension:
                                                                                  Lower(
                                                                                      Right(
                                                                                          Fila.Name,
                                                                                          Len(Fila.Name) - Find("." , Fila.Name)
                                                                                      )
                                                                                  ),

                                                                              // Convertir el archivo a texto Base64
                                                                              base64Contenido:
                                                                                  Mid(
                                                                                      JSON(
                                                                                          Fila.Value,
                                                                                          JSONFormat.IncludeBinaryData 
                                                                                      ),
                                                                                      Find(
                                                                                          ",",
                                                                                          JSON(
                                                                                              Fila.Value,
                                                                                              JSONFormat.IncludeBinaryData
                                                                                          )
                                                                                      ) + 1,
                                                                                      Len(
                                                                                          JSON(
                                                                                              Fila.Value,
                                                                                              JSONFormat.IncludeBinaryData
                                                                                          )
                                                                                      ) -
                                                                                      Find(
                                                                                          ",",
                                                                                          JSON(
                                                                                              Fila.Value,
                                                                                              JSONFormat.IncludeBinaryData
                                                                                          )
                                                                                      ) - 1
                                                                                  )
                                                                          },

                                                                          With(
                                                                              {
                                                                                  // Calcular el peso real del archivo
                                                                                  nuevoBytes: Len(base64Contenido) * 0.75
                                                                              },

                                                                              // Validar el Formato
                                                                              If(
                                                                                  !(extension in ["png","jpg","jpeg"]),
                                                                                  Collect(SpvNvCmc_colErroresAdjuntos, { Tipo: "Formato" }),

                                                                                  // Validar la Cantidad
                                                                                  If(
                                                                                      CountRows(SpvNvCmc_var_uploadFile_listeAttachment) >= Self.MaxAttachments,
                                                                                      Collect(SpvNvCmc_colErroresAdjuntos, { Tipo: "Cantidad" }),

                                                                                      // Validar el Tamaño: Que el archivo nuevo (o la suma) no supere los 25 MB
                                                                                      If(
                                                                                          nuevoBytes > SpvNvCmc_varLimiteBytes Or Sum(SpvNvCmc_var_uploadFile_listeAttachment, PesoBytes) + nuevoBytes > SpvNvCmc_varLimiteBytes,

                                                                                          Collect(SpvNvCmc_colErroresAdjuntos, { Tipo: "Tamano" }),

                                                                                          // Si pasa todas las validaciones, lo guardamos en la colección final
                                                                                          Collect(
                                                                                              SpvNvCmc_var_uploadFile_listeAttachment,
                                                                                              {
                                                                                                  nombre: Fila.Name,
                                                                                                  contenido: base64Contenido,
                                                                                                  PesoBytes: nuevoBytes,
                                                                                                  VistaPrevia: Fila.Value
                                                                                              }
                                                                                          )
                                                                                      )
                                                                                  )
                                                                              )
                                                                          )
                                                                      )
                                                                  )
                                                              );

                                                              // 4️⃣ Definir el Mensaje de error si algo falló
                                                              Set(
