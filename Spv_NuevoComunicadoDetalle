  Spv_NuevoComunicadoDetalle:
    Properties:
      Fill: =ColorValue(Var_ColorFondoLateral)
      LoadingSpinnerColor: =RGBA(56, 96, 178, 1)
      OnVisible: "=UpdateContext({ menuSelected: 5});\r\nIf(\r\n    !IsBlank(Var_SpvCmcComunicadoSeleccionada),\r\n    UpdateContext({\r\n        var_RangeDatePicker_DateStart: If(\r\n            !IsBlank(Var_SpvCmcComunicadoSeleccionada.FechaInicio),\r\n            DateValue(Text(Var_SpvCmcComunicadoSeleccionada.FechaInicio)),\r\n            Blank()\r\n        ),\r\n        var_RangeDatePicker_DateEnd: If(\r\n            !IsBlank(Var_SpvCmcComunicadoSeleccionada.FechaFin),\r\n            DateValue(Text(Var_SpvCmcComunicadoSeleccionada.FechaFin)),\r\n            Blank()\r\n        ),\r\n        varDirigidoSelected: { Value: If(!IsBlank(Text(Var_SpvCmcComunicadoSeleccionada.Gerencia)),\"Gerencia\",!IsBlank(Text(Var_SpvCmcComunicadoSeleccionada.Pais)),\"País\",\"Todos\") },\r\n        varTextoSeleccionado: If(!IsBlank(Var_SpvCmcComunicadoSeleccionada.Gerencia),Text(Var_SpvCmcComunicadoSeleccionada.Gerencia),!IsBlank(Var_SpvCmcComunicadoSeleccionada.Pais),Text(Var_SpvCmcComunicadoSeleccionada.Pais)),\r\n        varDiaInicioSelected : If(!IsBlank(Var_SpvCmcComunicadoSeleccionada.DiaInicio),{ Value: IfError(Value(Var_SpvCmcComunicadoSeleccionada.DiaInicio), Blank()) }),\r\n        varMesInicioSelected : If(!IsBlank(Var_SpvCmcComunicadoSeleccionada.MesInicio),{ Value: IfError(Value(Var_SpvCmcComunicadoSeleccionada.MesInicio), Blank()) }),\r\n        varDiaFinSelected : If(!IsBlank(Var_SpvCmcComunicadoSeleccionada.DiaFin),{ Value: IfError(Value(Var_SpvCmcComunicadoSeleccionada.DiaFin), Blank()) }),\r\n        varMesFinSelected : If(!IsBlank(Var_SpvCmcComunicadoSeleccionada.MesFin),{ Value: IfError(Value(Var_SpvCmcComunicadoSeleccionada.MesFin), Blank()) }),\r\n        varOpenDropDownDirigidoOpcion: false,\r\n        CloseAlertSpvNuevoComunicadoDetalle:Blank()\r\n    });\r\n\r\n        // ─────────────────────────────────────────────────────────\r\n    // BLOQUE 2: Poblamos colDirigidoOpcionSeleccionadas\r\n    // La colección es la FUENTE DE VERDAD del combobox\r\n    // Usamos Split() para convertir el texto \"A; B; C\" en filas\r\n    // ─────────────────────────────────────────────────────────\r\n    If(\r\n        !IsBlank(Var_SpvCmcComunicadoSeleccionada.Gerencia),\r\n\r\n        // CASO GERENCIA: Split del campo Gerencia\r\n        ClearCollect(\r\n            colDirigidoOpcionSeleccionadas,\r\n            ForAll(\r\n                Split(Var_SpvCmcComunicadoSeleccionada.Gerencia, \";\"),\r\n                If(!IsBlank(Trim(Value)), Trim(Value))\r\n            )\r\n        ),\r\n\r\n        !IsBlank(Var_SpvCmcComunicadoSeleccionada.Pais),\r\n\r\n        // CASO PAÍS: Split del campo Pais\r\n        ClearCollect(\r\n            colDirigidoOpcionSeleccionadas,\r\n            ForAll(\r\n                Split(Var_SpvCmcComunicadoSeleccionada.Pais, \";\"),\r\n                If(!IsBlank(Trim(Value)), Trim(Value))\r\n            )\r\n        ),\r\n\r\n        // CASO TODOS: Colección vacía (no hay selección específica)\r\n        Clear(colDirigidoOpcionSeleccionadas)\r\n    );\r\n\r\n    // ─────────────────────────────────────────────────────────────────\r\n    // BLOQUE 3: varTextoSeleccionado SIEMPRE se deriva de la colección\r\n    // Así es 100% consistente con lo que hace el combobox al interactuar\r\n    // ─────────────────────────────────────────────────────────────────\r\n    UpdateContext({\r\n        varTextoSeleccionado: If(\r\n            !IsEmpty(colDirigidoOpcionSeleccionadas),\r\n            Concat(colDirigidoOpcionSeleccionadas, Value, \"; \"),\r\n            \"Todos\"  // ← Texto display cuando no hay selección\r\n        )\r\n    });\r\n\r\n\r\n\r\n    Reset(SpvNvCmc_TxtITituloFormularioDetalle);\r\n    Reset(SpvNvCmc_TxtIDescripcionDetalle)\r\n    ,\r\n    \r\n    // Si no hay seleccionado, limpiamos\r\n    UpdateContext({\r\n        var_RangeDatePicker_DateStart: Blank(),\r\n        var_RangeDatePicker_DateEnd: Blank()\r\n    });\r\n    Clear(colDirigidoOpcionSeleccionadas)\r\n);\r\nIf( Text(Var_SpvCmcComunicadoSeleccionada.Recurrente) = \"True\",\r\n    ClearCollect(colEstadoRecurrenteSeleccionadas,{ Value: \"Recurrente\" }),\r\n    Clear(colEstadoRecurrenteSeleccionadas)\r\n);\r\nIf( Text(Var_SpvCmcComunicadoSeleccionada.EstadoComunicado) = \"Activo\",\r\n    ClearCollect(colEstadoEstadoCmcSeleccionadas,{ Value: \"Activo\" }),\r\n    ClearCollect(colEstadoEstadoCmcSeleccionadas,{ Value: \"Inactivo\" })\r\n);\r\n// 1. Limpiamos la colección de subida (porque al entrar, aún no hay \"nuevos\" cambios)\r\nClear(SpvNvCmc_var_uploadFile_listeAttachmentDetalle);"
