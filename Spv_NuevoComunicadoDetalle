                                                            NoAttachmentsText: =
                                                            OnAddFile: |-
                                                              =// 1️⃣ Establecer el límite máximo estricto a 25 MB en bytes
                                                              Set(
                                                                  SpvNvCmc_varLimiteBytesDetalle,
                                                                  25 * 1024 * 1024
                                                              );

                                                              // 2️⃣ Limpiar los errores anteriores
                                                              Clear(SpvNvCmc_colErroresAdjuntosDetalle);

                                                              // 3️⃣ Recorrer los archivos que el usuario acaba de adjuntar
                                                              ForAll(
                                                                  Self.Attachments As Fila,

                                                                  // Verificar que el archivo no esté duplicado
                                                                  If(
                                                                      IsBlank(
                                                                          LookUp(
                                                                              SpvNvCmc_var_uploadFile_listeAttachmentDetalle As A,
                                                                              A.nombre = Fila.Name
                                                                          )
                                                                      ),

                                                                      With(
                                                                          {
                                                                              // Extraer la extensión del archivo
                                                                              extension:
                                                                                  Lower(
                                                                                      Right(
                                                                                          Fila.Name,
                                                                                          Len(Fila.Name) - Find("." , Fila.Name)
                                                                                      )
                                                                                  ),

                                                                              // Convertir el archivo a texto Base64
                                                                              base64Contenido:
                                                                                  Mid(
                                                                                      JSON(
                                                                                          Fila.Value,
                                                                                          JSONFormat.IncludeBinaryData 
                                                                                      ),
                                                                                      Find(
                                                                                          ",",
                                                                                          JSON(
                                                                                              Fila.Value,
                                                                                              JSONFormat.IncludeBinaryData
                                                                                          )
                                                                                      ) + 1,
                                                                                      Len(
                                                                                          JSON(
                                                                                              Fila.Value,
                                                                                              JSONFormat.IncludeBinaryData
                                                                                          )
                                                                                      ) -
                                                                                      Find(
                                                                                          ",",
                                                                                          JSON(
                                                                                              Fila.Value,
                                                                                              JSONFormat.IncludeBinaryData
                                                                                          )
                                                                                      ) - 1
                                                                                  )
                                                                          },

                                                                          With(
                                                                              {
                                                                                  // Calcular el peso real del archivo
                                                                                  nuevoBytes: Len(base64Contenido) * 0.75
                                                                              },

                                                                              // Validar el Formato
                                                                              If(
                                                                                  !(extension in ["png","jpg","jpeg"]),
                                                                                  Collect(SpvNvCmc_colErroresAdjuntosDetalle, { Tipo: "Formato" }),

                                                                                  // Validar la Cantidad
                                                                                  If(
                                                                                      CountRows(SpvNvCmc_var_uploadFile_listeAttachmentDetalle) >= Self.MaxAttachments,
                                                                                      Collect(SpvNvCmc_colErroresAdjuntosDetalle, { Tipo: "Cantidad" }),

                                                                                      // Validar el Tamaño: Que el archivo nuevo (o la suma) no supere los 25 MB
                                                                                      If(
                                                                                          nuevoBytes > SpvNvCmc_varLimiteBytesDetalle Or Sum(SpvNvCmc_var_uploadFile_listeAttachmentDetalle, PesoBytes) + nuevoBytes > SpvNvCmc_varLimiteBytesDetalle,

                                                                                          Collect(SpvNvCmc_colErroresAdjuntosDetalle, { Tipo: "Tamano" }),

                                                                                          // Si pasa todas las validaciones, lo guardamos en la colección final
                                                                                          Collect(
                                                                                              SpvNvCmc_var_uploadFile_listeAttachmentDetalle,
                                                                                              {
                                                                                                  nombre: Fila.Name,
                                                                                                  contenido: base64Contenido,
                                                                                                  PesoBytes: nuevoBytes,
                                                                                                  VistaPrevia: Fila.Value
                                                                                              }
                                                                                          )
                                                                                      )
                                                                                  )
                                                                              )
                                                                          )
                                                                      )
                                                                  )
                                                              );

                                                              // 4️⃣ Definir el Mensaje de error si algo falló
                                                              Set(
                                                                  SpvNvCmc_varMensajeErrorDetalle,
                                                                  If(
                                                                      !IsBlank(LookUp(SpvNvCmc_colErroresAdjuntosDetalle, Tipo = "Formato")),
                                                                      "Formato no permitido. Solo se aceptan PNG, JPG y JPEG.",
                                                                      !IsBlank(LookUp(SpvNvCmc_colErroresAdjuntosDetalle, Tipo = "Cantidad")),
                                                                      "Se alcanzó el número máximo de archivos permitidos.",
                                                                      !IsBlank(LookUp(SpvNvCmc_colErroresAdjuntosDetalle, Tipo = "Tamano")),
                                                                      "El tamaño del archivo no puede superar los 25 MB.",
                                                                      Blank()
                                                                  )
                                                              );

                                                              // 5️⃣ Mostrar alerta si existe un error
                                                              If(
                                                                  !IsBlank(SpvNvCmc_varMensajeErrorDetalle),
                                                                  UpdateContext(
                                                                      {
                                                                          CloseAlertSpvNuevoComunicadoDetalle: true,
                                                                          SpvNvCmcMensajeErrorDetalle: SpvNvCmc_varMensajeErrorDetalle
                                                                      }
                                                                  )
                                                              );

                                                              // 6️⃣ Reiniciar el control para permitir subir más archivos
                                                              Reset(Self)
                                                            PaddingLeft: =Parent.Width/2 - 150
                                                            PressedColor: =RGBA(255, 255, 255, 1)
