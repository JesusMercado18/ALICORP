  Spv_Comunicados:
    Properties:
      Fill: =ColorValue(Var_ColorFondoLateral)
      LoadingSpinnerColor: =RGBA(0, 120, 212, 1)
      OnVisible: |-
        =//----Variables-----
        UpdateContext({menuSelected: 5});
        UpdateContext({Var_Ctx_MostrarItems : false });
        UpdateContext({varOpenDropDownSpvCmcGerencia : false });
        UpdateContext({varOpenDropDownSpvCmcArea : false });
        UpdateContext({varOpenDropDownSpvCmcEstado : false });
        UpdateContext({var_RangeDatePicker : false });
        UpdateContext({var_RangeDatePicker_SelectMonthYear : false });
        UpdateContext({Var_SpvCmcDisplayModeArea: false});
        UpdateContext({Var_SpvCmcLoadingSpinnerVisible: true});
        //----Flujo----
        Set(Var_GridPageSizeSpvComunicados, 3);
        Set(Var_ResponseSpvComunicados,
            'LCP-001_Flow_SpvPaginacionComunicados'.Run(
                Var_GridPageSizeSpvComunicados,
                0,
                Concat(
                    Filter(colQuerysSpvComunicados, mark),
                    query,
                    " and "
                ),
                "NEXT"
            )
        );
        //----Variables respuesta flujo----
        Set(TotalItemSpvComunicados, Value(ParseJSON(Var_ResponseSpvComunicados.totalitems)));
        Set(Var_DataSpvComunicados, Table(ParseJSON(Var_ResponseSpvComunicados.response)));
        //----Datos para llenar galeria de comunicados---- 
        Clear(objGalleryDataSpvComunicados);
        ForAll(
            FirstN(Var_DataSpvComunicados,Var_GridPageSizeSpvComunicados),
            Collect(
                objGalleryDataSpvComunicados,
                {
                    ID:                 ThisRecord.Value.ID,
                    Gerencia:           ThisRecord.Value.Gerencia,        
                    Pais:               ThisRecord.Value.Pais,          
                    Cabecera:           ThisRecord.Value.Cabecera,    
                    Cuerpo:             ThisRecord.Value.Cuerpo,           
                    Imagen:             Text(ThisRecord.Value.ImagenBase64),
                    URLimagen:          ThisRecord.Value.URLimagen,
                    UsuarioCreador:     ThisRecord.Value.UsuarioCreador, 
                    FechaCreacion:      ThisRecord.Value.FechaCreacion,
                    FechaInicio:        ThisRecord.Value.FechaInicio,    
                    FechaFin:           ThisRecord.Value.FechaFin,  
                    DiaInicio:          ThisRecord.Value.DiaInicio,    
                    DiaFin:             ThisRecord.Value.DiaFin,     
                    MesInicio:          ThisRecord.Value.MesInicio,    
                    MesFin:             ThisRecord.Value.MesFin,     
                    Estado:             ThisRecord.Value.Estado,     
                    Creado:             ThisRecord.Value.Creado,      
                    EstadoComunicado:   ThisRecord.Value.EstadoComunicado,
                    Recurrente:         ThisRecord.Value.Recurrente
                }
            )
        );
        //----Guardamos el primer ID REAL de todo el dataset----
        Set(Var_FirstIDSpvComunicados, Min(objGalleryDataSpvComunicados, ID));
        //----Control real de NEXT (Top + 1)----
        Set(Var_HasPrevSpvComunicados, false);
        Set(Var_HasNextSpvComunicados, CountRows(Var_DataSpvComunicados) > Var_GridPageSizeSpvComunicados);
        Set(Var_CurrentPageSpvComunicados, 1);
        UpdateContext({Var_SpvCmcLoadingSpinnerVisible: false});
