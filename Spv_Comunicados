                                          Items: "=With(\r\n    {\r\n        // 1. Variables globales de tiempo y usuario (Calculadas 1 sola vez)\r\n        _hoy: Today(),\r\n        _diaActual: Day(Today()),\r\n        _valorHoy: Month(Today()) * 100 + Day(Today()),\r\n        \r\n        _ultimoDiaMesActual: Day(DateAdd(Date(Year(Today()), Month(Today()) + 1, 1), -1, TimeUnit.Days)),\r\n        _esBisiestoActual: Day(DateAdd(Date(Year(Today()), 3, 1), -1, TimeUnit.Days)) = 29,\r\n        \r\n        // Limpiamos los datos del perfil desde el inicio\r\n        _usrGerencia: Trim(Text(Var_ProfileUser.Gerencia)),\r\n        _usrPais: Trim(Text(Var_ProfileUser.Pais))\r\n    },\r\n    Filter(\r\n        objGalleryDataSpvComunicados,\r\n        \r\n        // ==========================================================\r\n        // CONDICIÓN 1: ESTADO (Vigente y Activo)\r\n        // ==========================================================\r\n        Text(Estado) = \"Vigente\" && Text(EstadoComunicado) = \"Activo\" &&\r\n        \r\n        // ==========================================================\r\n        // CONDICIÓN 2: AUDIENCIA (Aplica a recurrentes y no recurrentes por igual)\r\n        // ==========================================================\r\n        (IsBlank(Gerencia) || Trim(Text(Gerencia)) = \"\" || Trim(Text(Gerencia)) = \"Todos\" || _usrGerencia in Text(Gerencia)) &&\r\n        (IsBlank(Pais) || Trim(Text(Pais)) = \"\" || Trim(Text(Pais)) = \"Todos\" || _usrPais in Text(Pais)) &&\r\n        \r\n        // ==========================================================\r\n        // CONDICIÓN 3: FECHAS Y RECURRENCIA (Evaluado como 1 sola condición plana)\r\n        // ==========================================================\r\n        (\r\n            // --- ESCENARIO A: NO RECURRENTE ---\r\n            (\r\n                !(Trim(Lower(Text(Recurrente))) in [\"true\", \"verdadero\", \"1\", \"sí\", \"si\"]) &&\r\n                Trim(Text(FechaInicio)) <> \"\" && Trim(Text(FechaFin)) <> \"\" && \r\n                _hoy >= DateValue(Left(Text(FechaInicio), 10), \"es-ES\") && \r\n                _hoy <= DateValue(Left(Text(FechaFin), 10), \"es-ES\")\r\n            )\r\n            ||\r\n            // --- ESCENARIO B: RECURRENCIA MENSUAL (Sin mes, solo días) ---\r\n            (\r\n                (Trim(Lower(Text(Recurrente))) in [\"true\", \"verdadero\", \"1\", \"sí\", \"si\"]) &&\r\n                (Trim(Text(MesInicio)) = \"\" || Value(Text(MesInicio)) = 0) &&\r\n                Value(Text(DiaInicio)) > 0 && Value(Text(DiaFin)) > 0 &&\r\n                If(\r\n                    // Evaluamos el límite: el día fin asignado o el último día real del mes actual\r\n                    Value(Text(DiaInicio)) <= If(Value(Text(DiaFin)) > _ultimoDiaMesActual, _ultimoDiaMesActual, Value(Text(DiaFin))),\r\n                    // Si el inicio es menor o igual al fin (Ej. 1 al 15)\r\n                    _diaActual >= Value(Text(DiaInicio)) && _diaActual <= If(Value(Text(DiaFin)) > _ultimoDiaMesActual, _ultimoDiaMesActual, Value(Text(DiaFin))),\r\n                    // Si el rango cruza el fin de mes (Ej. 25 al 5)\r\n                    _diaActual >= Value(Text(DiaInicio)) || _diaActual <= If(Value(Text(DiaFin)) > _ultimoDiaMesActual, _ultimoDiaMesActual, Value(Text(DiaFin)))\r\n                )\r\n            )\r\n            ||\r\n            // --- ESCENARIO C: RECURRENCIA ANUAL (Con meses y días) ---\r\n            (\r\n                (Trim(Lower(Text(Recurrente))) in [\"true\", \"verdadero\", \"1\", \"sí\", \"si\"]) &&\r\n                Value(Text(MesInicio)) > 0 && Value(Text(MesFin)) > 0 &&\r\n                Value(Text(DiaInicio)) > 0 && Value(Text(DiaFin)) > 0 &&\r\n                If(\r\n                    // Calculamos Rango Inicial vs Rango Final con validación bisiesta inline\r\n                    (Value(Text(MesInicio)) * 100 + Value(Text(DiaInicio))) <= \r\n                    (Value(Text(MesFin)) * 100 + If(Value(Text(MesFin)) = 2 && Value(Text(DiaFin)) = 29 && !_esBisiestoActual, 28, Value(Text(DiaFin)))),\r\n                    \r\n                    // Si es el mismo año (Ej. Mayo a Octubre)\r\n                    _valorHoy >= (Value(Text(MesInicio)) * 100 + Value(Text(DiaInicio))) && \r\n                    _valorHoy <= (Value(Text(MesFin)) * 100 + If(Value(Text(MesFin)) = 2 && Value(Text(DiaFin)) = 29 && !_esBisiestoActual, 28, Value(Text(DiaFin)))),\r\n                    \r\n                    // Si cruza a fin de año (Ej. Diciembre a Febrero)\r\n                    _valorHoy >= (Value(Text(MesInicio)) * 100 + Value(Text(DiaInicio))) || \r\n                    _valorHoy <= (Value(Text(MesFin)) * 100 + If(Value(Text(MesFin)) = 2 && Value(Text(DiaFin)) = 29 && !_esBisiestoActual, 28, Value(Text(DiaFin))))\r\n                )\r\n            )\r\n        )\r\n    )\r\n)"
