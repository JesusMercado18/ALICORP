  Spv_Soluciones:
    Properties:
      Fill: =ColorValue(Var_ColorFondoLateral)
      LoadingSpinnerColor: =RGBA(0, 120, 212, 1)
      OnVisible: |-
        =//----Variables-----
        UpdateContext({menuSelected: 6});
        UpdateContext({Var_Ctx_MostrarItems : false });
        //----Flujo----
        Set(Var_GridPageSizeSpvSoluciones, 5);
        Set(Var_ResponseSpvSoluciones,
            'LCP-001_Flow_SpvPaginacionSoluciones'.Run(
                Var_GridPageSizeSpvSoluciones,
                0,
                Concat(
                    Filter(colQuerysSpvSoluciones, mark),
                    query,
                    " and "
                ),
                "NEXT"
            )
        );
        //----Variables respuesta flujo----
        Set(TotalItemSpvSoluciones, Value(ParseJSON(Var_ResponseSpvSoluciones.totalitems)));
        Set(Var_DataSpvSoluciones, Table(ParseJSON(Var_ResponseSpvSoluciones.response)));
        //----Datos para llenar galeria de comunicados----
        Clear(objGalleryDataSpvSoluciones);
        ForAll(
            FirstN(Var_DataSpvSoluciones,Var_GridPageSizeSpvSoluciones),
            Collect(
                objGalleryDataSpvSoluciones,
                {
                    ID:             ThisRecord.Value.ID,
                    NombreAdjunto:  If(
                                        // Verificamos si hay adjuntos para evitar errores
                                        Boolean(ThisRecord.Value.Attachments), 
                                        Text(First(Table(ThisRecord.Value.AttachmentFiles)).Value.FileName), 
                                        Blank()
                                    ),
                    RutaAdjunto:    If(
                                        Boolean(ThisRecord.Value.Attachments), 
                                        Text(First(Table(ThisRecord.Value.AttachmentFiles)).Value.ServerRelativeUrl), 
                                        Blank()
                                    ),
                    Estado:         ThisRecord.Value.Estado,
                    Gerencia:       ThisRecord.Value.Gerencia,
                    Area:           ThisRecord.Value.Area,
                    Autor:          ThisRecord.Value.Autor
                }
            )
        );
        //----Guardamos el primer ID REAL de todo el dataset----
        Set(Var_FirstIDSpvSoluciones, Min(objGalleryDataSpvSoluciones, ID));
        //----Control real de NEXT (Top + 1)----
        Set(Var_HasPrevSpvSoluciones, false);
        Set(Var_HasNextSpvSoluciones, CountRows(Var_DataSpvSoluciones) > Var_GridPageSizeSpvSoluciones);
        Set(Var_CurrentPageSpvSoluciones, 1);
