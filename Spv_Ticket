      OnVisible: "=UpdateContext({ menuSelected: 3});\r\n/*\r\nSet(Var_SpvAgrupadorTicket; Filter('LCP-001_List_AgrupadorAnalistas' ; Usuario  =Var_EmailUser ).RolCompuestoAnalista);;\r\n// colAreasTicketSpv\r\n\r\nClear(colAreasSubAreasTicketSpv);;\r\n\r\nForAll(Var_SpvAgrupadorTicket As groupSpv; With( { datosFiltrosSpv: Filter('LCP-001_List_RolGerenciaAreaSubAreaPaisSoc'; RolGeneralNombre = groupSpv.RolCompuestoAnalista ) }; Collect(colAreasSubAreasTicketSpv; datosFiltrosSpv ) ));;\r\n\r\nClearCollect(colAreasTicketSpv; Distinct(colAreasSubAreasTicketSpv;Area));;\r\n\r\nClearCollect(colGerenciasTicketSpv;Distinct(colAreasSubAreasTicketSpv;Gerencia));;\r\n*/\r\n\r\nClearCollect(colFiltrosTicketSpv,\r\n    {Title: \"Gerencia\" ,      Open: false},\r\n	{Title: \"Área\" ,          Open: false},\r\n	{Title: \"Subárea\" ,       Open: false},\r\n	{Title: \"Requerimiento\" , Open: false},\r\n	{Title: \"Atendido por\" ,  Open: false}\r\n    );\r\n\r\n// Cada vez que el usuario visualiza su bandeja de ticket, debemos actualizar \r\nClearCollect(col_SpvTipoSolicitud, Filter(Distinct('LCP-001_List_TicketSolicitudes', TipoSolicitud), !IsBlank(Value)));\r\nClearCollect(col_SpvAtendidoPor,Filter(Distinct('LCP-001_List_TicketSolicitudes', NombreAtendidoPor), !IsBlank(Value)));\r\n\r\n// 1. Limpiamos la colección antes de cargar los datos nuevos\r\nClear(colFiltrosTicketChildSpv);\r\n\r\n// 2. Insertar GERENCIAS (Valores únicos de la lista 'GerenciaArea')\r\nCollect(\r\n    colFiltrosTicketChildSpv,\r\n    ForAll(\r\n        col_gblGerencia,\r\n        {\r\n            Title: \"Gerencia\",\r\n            Value: ThisRecord.Nombre,\r\n            ParentGerencia: \"\",\r\n            ParentArea: \"\"\r\n        }\r\n    )\r\n);\r\n\r\n// 3. Insertar ÁREAS (Relacionadas con su Gerencia padre)\r\nCollect(\r\n    colFiltrosTicketChildSpv,\r\n    ForAll(\r\n        col_gblGerenciaArea,\r\n        {\r\n            Title: \"Área\",\r\n            Value: Area, // Asegúrate de que el nombre de la columna en SP sea 'Area'\r\n            ParentGerencia: Gerencia,\r\n            ParentArea: \"\"\r\n        }\r\n    )\r\n);\r\n\r\n// 4. Insertar SUBÁREAS (Relacionadas con Área y buscando su Gerencia)\r\nCollect(\r\n    colFiltrosTicketChildSpv,\r\n    ForAll(\r\n        col_gblAreaSubArea,\r\n        {\r\n            Title: \"Subárea\",\r\n            Value: SubArea, // Asegúrate de que el nombre de la columna en SP sea 'SubArea'\r\n            ParentArea: Area,\r\n            // Buscamos la Gerencia correspondiente en la primera lista para mantener la jerarquía\r\n            ParentGerencia: LookUp(col_gblGerenciaArea, Area = ThisRecord.Area, Gerencia)\r\n        }\r\n    )\r\n);\r\nCollect(\r\n    colFiltrosTicketChildSpv,\r\n    ForAll(\r\n        col_SpvTipoSolicitud, // Nombre de tu lista de SharePoint\r\n        {\r\n            Title: \"Requerimiento\",\r\n            Value: ThisRecord.Value, // Cambia 'NombreRequerimiento' por tu columna de SP\r\n            ParentGerencia: \"\",\r\n            ParentArea: \"\"\r\n        }\r\n    )\r\n);\r\nCollect(\r\n    colFiltrosTicketChildSpv,\r\n    ForAll(\r\n        col_SpvAtendidoPor, // Nombre de tu lista de SharePoint\r\n        {\r\n            Title: \"Atendido por\",\r\n            Value: ThisRecord.Value, // Cambia 'NombreRequerimiento' por tu columna de SP\r\n            ParentGerencia: \"\",\r\n            ParentArea: \"\"\r\n        }\r\n    )\r\n);\r\n\r\nClearCollect(\r\n    Col_Spv_QueryTicket,\r\n    { input: \"Codigo\",            mark: false, query: \"\" },\r\n    { input: \"SolicitanteNombre\", mark: false, query: \"\" },\r\n    { input: \"NombreAtendidoPor\", mark: false, query: \"\" },\r\n    { input: \"FechaCreado\",       mark: false, query: \"\" },\r\n    { input: \"EstadoActual\",            mark: false, query: \"\" },\r\n    { input: \"Area\",         mark: false, query: \"\" },\r\n    { input: \"SubArea\",           mark: false, query: \"\" },\r\n    { input: \"Prioridad\",         mark: false, query: \"\" },\r\n    { input: \"AprobadorNombre\",   mark: false, query: \"\" },\r\n    { input: \"TipoSolicitud\", mark: false, query: \"\" },\r\n    { input: \"Gerencia\",          mark: false, query: \"\" },\r\n    { input: \"ID\",                mark: false, query: \"\" },\r\n    {\r\n  input: \"AnalistaCorreo\",\r\n  mark: false,\r\n  query: \"(AnalistaCorreo eq 'test@alicorp.pe' or SolicitanteCorreo eq 'test@alicorp.pe')\"\r\n}\r\n);\r\n\r\nSet(Var_Spv_Indicadores,'LCP-001_Flow_IndicadoresTicket'.Run(\"(AnalistaCorreo eq '\" & \"test@alicorp.pe\" & \"'\" &\" or SolicitanteCorreo eq '\" & \"test@alicorp.pe\" & \"')\",101));\r\n\r\nSet(Var_GridPageSizeSpv, 5);\r\nSet(Var_CurrentPageSpv, 1);\r\n// Configuración para el motor:\r\nSet(Var_TargetIDSpv, 0);\r\nSet(Var_DirectionSpv, \"NEXT\");\r\nSet(Var_IsIndividualSpv, false);\r\nSelect(Spv_btn_MotorPaginacion); // <--- Ejecuta la lógica\r\n\r\nUpdateContext({ Var_Ctx_MostrarItems : false });\r\n/*\r\nSet(\r\n    Var_ResponseSpv;\r\n    'LCP-001_Flow_SpvPaginacionTicket'.Run(\r\n        Var_GridPageSizeSpv;\r\n        0;\r\n        Concat(\r\n            Filter(Col_Spv_QueryTicket; mark);\r\n            query;\r\n            \" and \"\r\n        );\r\n        \"NEXT\"\r\n    )\r\n);;\r\n\r\n\r\nSet(TotalItemSpv; Value(ParseJSON(Var_ResponseSpv.totalitems)));;\r\n\r\nSet(\r\n    Var_DataSpv;\r\n    Table(ParseJSON(Var_ResponseSpv.response))\r\n);;\r\n\r\nClear(objGalleryDataSpv);;\r\nForAll(\r\n    FirstN(Var_DataSpv; Var_GridPageSizeSpv);\r\n    Collect(\r\n        objGalleryDataSpv;\r\n        {\r\n            ID: Value(ThisRecord.Value.ID);\r\n            Gerencia: Text(ThisRecord.Value.Gerencia);\r\n            Area: Text(ThisRecord.Value.Area);\r\n            SubArea: Text(ThisRecord.Value.SubArea);\r\n            Pais: Text(ThisRecord.Value.Pais);\r\n            Sociedad: Text(ThisRecord.Value.Sociedad);\r\n            Prioridad: Text(ThisRecord.Value.Prioridad);\r\n            AnalistaRol: Text(ThisRecord.Value.AnalistaRol);\r\n            Aprobacion: Text(ThisRecord.Value.Aprobacion);\r\n            SLA: Value(ThisRecord.Value.SLA);\r\n            SolicitanteCorreo: Text(ThisRecord.Value.SolicitanteCorreo);\r\n            SolicitanteNombre: Text(ThisRecord.Value.SolicitanteNombre);\r\n            SolicitantePais: Text(ThisRecord.Value.SolicitantePais);\r\n            SolicitanteSociedad: Text(ThisRecord.Value.SolicitanteSociedad);\r\n            AnalistaCorreo: Text(ThisRecord.Value.AnalistaCorreo);\r\n            AnalistaNombre: Text(ThisRecord.Value.AnalistaNombre);\r\n            Detalle: Text(ThisRecord.Value.Detalle);\r\n            AprobadorCorreo: Text(ThisRecord.Value.AprobadorCorreo);\r\n            AprobadorNombre: Text(ThisRecord.Value.AprobadorNombre);\r\n            Var_iosAprobadores: Text(ThisRecord.Value.Var_iosAprobadores);\r\n            FechaCreado: DateTimeValue(ThisRecord.Value.FechaCreado);\r\n            FechaVencimiento: DateTimeValue(ThisRecord.Value.FechaVencimiento);\r\n            NombreAtendidoPor: Text(ThisRecord.Value.NombreAtendidoPor);\r\n            CorreoAtendidoPor: Text(ThisRecord.Value.CorreoAtendidoPor);\r\n            FechaModificado: DateTimeValue(ThisRecord.Value.FechaModificado);\r\n            Codigo: Text(ThisRecord.Value.Codigo);\r\n            Requerimiento: Text(ThisRecord.Value.Requerimiento);\r\n            TipoSolicitud: Text(ThisRecord.Value.TipoSolicitud);\r\n            AprobadoresCheck: Text(ThisRecord.Value.AprobadoresCheck);\r\n            Estado: Text(ThisRecord.Value.EstadoActual);\r\n            Asunto: Text(ThisRecord.Value.Asunto);\r\n            Descripcion: Text(ThisRecord.Value.Descripcion);\r\n            MotivoDerivacion: Text(ThisRecord.Value.MotivoDerivacion);\r\n            ConfiguracionTicket: Text(ThisRecord.Value.ConfiguracionTicket)\r\n        }\r\n    )\r\n);;\r\n\r\nSet(Var_FirstIDSpv; Min(objGalleryDataSpv; ID));;\r\n\r\nSet(Var_HasPrevSpv; false);;\r\nSet(Var_HasNextSpv; CountRows(Var_DataSpv) > Var_GridPageSizeSpv);;\r\nSet(Var_CurrentPageSpv; 1);;\r\n\r\nClearCollect(colFiltrosTicketSpv;\r\n    {Title: \"Gerencia\" ;      Open: false};\r\n	{Title: \"Área\" ;          Open: false};\r\n	{Title: \"Subárea\" ;       Open: false};\r\n	{Title: \"Requerimiento\" ; Open: false};\r\n	{Title: \"Atendido por\" ;  Open: false}\r\n    );;\r\n    \r\nClearCollect(colFiltrosTicketChildSpv;\r\n\r\n    { Title: \"Gerencia\"; Value: \"Gerencia Tesorería Operativa y P2P\"; ParentGerencia: \"\"; ParentArea: \"\" };\r\n    { Title: \"Gerencia\"; Value: \"Gerencia Servicios al Colaborador\";  ParentGerencia: \"\"; ParentArea: \"\" };\r\n    { Title: \"Gerencia\"; Value: \"Gerencia Créditos Back Office\";       ParentGerencia: \"\"; ParentArea: \"\" };\r\n\r\n    { Title: \"Área\"; Value: \"Nuevos Servicios\";    ParentGerencia: \"Gerencia Tesorería Operativa y P2P\"; ParentArea: \"\" };\r\n    { Title: \"Área\"; Value: \"Cuentas por pagar\";   ParentGerencia: \"Gerencia Tesorería Operativa y P2P\"; ParentArea: \"\" };\r\n    { Title: \"Área\"; Value: \"Tesorería Operativa\"; ParentGerencia: \"Gerencia Tesorería Operativa y P2P\"; ParentArea: \"\" };\r\n\r\n    { Title: \"Área\"; Value: \"Nóminas Perú\";   ParentGerencia: \"Gerencia Servicios al Colaborador\"; ParentArea: \"\" };\r\n    { Title: \"Área\"; Value: \"Nóminas Países\"; ParentGerencia: \"Gerencia Servicios al Colaborador\"; ParentArea: \"\" };\r\n    { Title: \"Área\"; Value: \"Seguros\";        ParentGerencia: \"Gerencia Servicios al Colaborador\"; ParentArea: \"\" };\r\n    { Title: \"Área\"; Value: \"Administración de personal y riesgos\"; ParentGerencia: \"Gerencia Servicios al Colaborador\"; ParentArea: \"\" };\r\n\r\n    { Title: \"Área\"; Value: \"Cobranzas\";            ParentGerencia: \"Gerencia Créditos Back Office\"; ParentArea: \"\" };\r\n    { Title: \"Área\"; Value: \"Créditos Back Office\"; ParentGerencia: \"Gerencia Créditos Back Office\"; ParentArea: \"\" };\r\n    { Title: \"Área\"; Value: \"Gestión Comercial\";    ParentGerencia: \"Gerencia Créditos Back Office\"; ParentArea: \"\" };\r\n\r\n    { Title: \"Subárea\"; Value: \"Nóminas Perú\";   ParentGerencia: \"Gerencia Servicios al Colaborador\"; ParentArea: \"Nóminas Perú\" };\r\n    { Title: \"Subárea\"; Value: \"Nóminas Países\"; ParentGerencia: \"Gerencia Servicios al Colaborador\"; ParentArea: \"Nóminas Países\" };\r\n    { Title: \"Subárea\"; Value: \"Seguros\";        ParentGerencia: \"Gerencia Servicios al Colaborador\"; ParentArea: \"Seguros\" };\r\n    { Title: \"Subárea\"; Value: \"Administración de personal y riesgos\"; ParentGerencia: \"Gerencia Servicios al Colaborador\"; ParentArea: \"Administración de personal y riesgos\" }\r\n);;\r\n\r\nCollect(\r\n    colFiltrosTicketChildSpv;\r\n    { Title: \"Requerimiento\"; Value: \"Todos\"; ParentGerencia: \"\"; ParentArea: \"\" }\r\n);;\r\n\r\nForAll(\r\n    Filter(Distinct('LCP-001_List_TicketSolicitudes'; TipoSolicitud); !IsBlank(Value));\r\n    Collect(\r\n        colFiltrosTicketChildSpv;\r\n        {\r\n          Title: \"Requerimiento\";\r\n          Value: ThisRecord.Value;\r\n          ParentGerencia: \"\";\r\n          ParentArea: \"\" \r\n        }\r\n    )\r\n);;\r\n\r\nCollect(colFiltrosTicketChildSpv;\r\n    { Title: \"Atendido por\"; Value: \"Todos\"; ParentGerencia: \"\"; ParentArea: \"\" }\r\n);;\r\n\r\nForAll(\r\n    Filter(Distinct('LCP-001_List_TicketSolicitudes'; NombreAtendidoPor); !IsBlank(Value));\r\n    Collect(\r\n        colFiltrosTicketChildSpv;\r\n        {\r\n            Title: \"Atendido por\";\r\n            Value: ThisRecord.Value; \r\n            ParentGerencia: LookUp(objGalleryDataSpv; NombreAtendidoPor = ThisRecord.NombreAtendidoPor; Gerencia);\r\n            ParentArea: LookUp(objGalleryDataSpv; NombreAtendidoPor = ThisRecord.NombreAtendidoPor; Area)\r\n        }\r\n    )\r\n);;\r\n\r\nClearCollect(colMotivoDerivacionSpv; [\"Especialización técnica\";\"Capacidad\";\"Nivel de autorización\";\"Error de asignación\";\"Dependencia externa\";\"Otro\"])\r\n\r\n*/\r\n\r\nClearCollect(\r\n    colIndicadoresTicketSpv,\r\n    { Title: \"Total de Tickets\", Cantidad: If(Value(Var_Spv_Indicadores.total) > 100, \"99+\", Text(Var_Spv_Indicadores.total)) },\r\n    { Title: \"Cerrado\", Cantidad: If(Value(Var_Spv_Indicadores.cerrado) > 100, \"99+\", Text(Var_Spv_Indicadores.cerrado)) },\r\n    { Title: \"En proceso\", Cantidad: If(Value(Var_Spv_Indicadores.en_proceso) > 100, \"99+\", Text(Var_Spv_Indicadores.en_proceso)) },\r\n    { Title: \"Rechazado\", Cantidad: If(Value(Var_Spv_Indicadores.rechazado) > 100, \"99+\", Text(Var_Spv_Indicadores.rechazado)) },\r\n    { Title: \"Observados\", Cantidad: If(Value(Var_Spv_Indicadores.observados) > 100, \"99+\", Text(Var_Spv_Indicadores.observados)) },\r\n    { Title: \"Espera de aprobación\", Cantidad: If(Value(Var_Spv_Indicadores.en_espera_de_aprobacion) > 100, \"99+\", Text(Var_Spv_Indicadores.en_espera_de_aprobacion)) },\r\n    { Title: \"Resuelto\", Cantidad: If(Value(Var_Spv_Indicadores.resuelto) > 100, \"99+\", Text(Var_Spv_Indicadores.resuelto)) },\r\n    { Title: \"En revisión\", Cantidad: If(Value(Var_Spv_Indicadores.en_revision) > 100, \"99+\", Text(Var_Spv_Indicadores.en_revision)) },\r\n    { Title: \"Derivado\", Cantidad: If(Value(Var_Spv_Indicadores.derivado) > 100, \"99+\", Text(Var_Spv_Indicadores.derivado)) }\r\n);"
