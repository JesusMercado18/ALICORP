Screens:
  Spv_Catalogo:
    Properties:
      Fill: =ColorValue(Var_ColorFondoLateral)
      LoadingSpinnerColor: =RGBA(0, 120, 212, 1)
      OnVisible: |
        =UpdateContext({ 
            menuSelected: 2,
            Var_Ctx_MostrarItemsCatalogoSpv: false,
            Var_Ctx_TicketPopulares: true,
            Var_Ctx_Gerencias: false,
            Var_Ctx_Areas: false,
            Var_Ctx_GerenciaSeleccionada: Blank(),
            Var_Ctx_AreaSeleccionada: Blank(),
            ctx_GerenciaExpandida: Blank()
        });

        // 2. Limpiar selecciones visuales explícitas en las Galerías (UI Reset)
        // Nota: Resetear la galería padre reinicia implícitamente la galería anidada de Áreas
        Reset(SpvCtg_GalFiltrosGerencia);
        Reset(SpvCtg_GalItemsCatalogoServicio);
        Set(Var_SpvCatalogoServicioSeleccionada, Blank());

        // 3. Asegurar que los filtros OData regresen a estado 0
        Patch(
            colQuerysSpvCatalogoServicio, 
            LookUp(colQuerysSpvCatalogoServicio, input = "Gerencia"), 
            {mark: false, query: ""}
        );
        Patch(
            colQuerysSpvCatalogoServicio, 
            LookUp(colQuerysSpvCatalogoServicio, input = "Area"), 
            {mark: false, query: ""}
        );

        // 4. Configuración inicial para el motor de Paginación
        Set(Var_GridPageSizeSpvCatalogoServicio, 2);
        Set(Var_CurrentPageSpvCatalogoServicio, 1);
        Set(Var_TargetIDSpvCatalogoServicio, 0);
        Set(Var_DirectionSpvCatalogoServicio, "NEXT");
        Set(Var_IsIndividualSpvCatalogoServicio, false);

        // 5. Ejecutar la lógica de búsqueda en el motor
        Select(Spv_BtnMotorPaginacionCatalogoServicio);
    Children:
      - Spv_BtnMotorPaginacionCatalogoServicio:
          Control: Classic/Button@2.2.0
          Properties:
            BorderColor: =ColorFade(Self.Fill, -15%)
            Color: =RGBA(255, 255, 255, 1)
            DisabledBorderColor: =RGBA(166, 166, 166, 1)
            Fill: =RGBA(56, 96, 178, 1)
            Font: =Font.'Open Sans'
            Height: =34
            HoverBorderColor: =ColorFade(Self.BorderColor, 20%)
            HoverColor: =RGBA(255, 255, 255, 1)
            HoverFill: =ColorFade(RGBA(56, 96, 178, 1), -20%)
            OnSelect: |-
              =UpdateContext({Var_SpvCtgLoadingSpinnerVisible: true});
              // 1. Llamada al flujo con variables dinámicas
              Set(
                  Var_ResponseSpvCatalogoServicio,
                  'LCP-001_Flow_SpvPaginacionCatalogoServicio'.Run(
                      If(Var_IsIndividualSpvCatalogoServicio, Text(varTotalRegistrosCatalogoServicio), Text(Var_GridPageSizeSpvCatalogoServicio)),
                      Text(Var_TargetIDSpvCatalogoServicio),
                      Concat(Filter(colQuerysSpvCatalogoServicio, mark), query, " and "),
                      Var_DirectionSpvCatalogoServicio
                  )
              );

              // 2. Procesar respuesta
              Set(Var_DataSpvCatalogoServicio, Table(ParseJSON(Var_ResponseSpvCatalogoServicio.response)));
              Set(TotalItemSpvCatalogoServicio, Value(ParseJSON(Var_ResponseSpvCatalogoServicio.totalitems)));

              // 3. Limpiar y Mapear (Una sola vez en toda la App)
              Clear(objGalleryDataSpvCatalogoServicio);
              ForAll(
                  // Si es paginación individual usamos LastN; si no; FirstN
                  If(Var_IsIndividualSpvCatalogoServicio,
                      LastN(FirstN(Var_DataSpvCatalogoServicio, varTotalRegistrosCatalogoServicio), Min(Var_GridPageSizeSpvCatalogoServicio, CountRows(Var_DataSpvCatalogoServicio) - (Var_GridPageSizeSpvCatalogoServicio * (Var_CurrentPageSpvCatalogoServicio - 1)))),
                      FirstN(Var_DataSpvCatalogoServicio, Var_GridPageSizeSpvCatalogoServicio)
                  ),
                  Collect(
                      objGalleryDataSpvCatalogoServicio,
                      {
                          ID: Value(ThisRecord.Value.ID),
                          Gerencia: Text(ThisRecord.Value.Gerencia),
                          Area: Text(ThisRecord.Value.Area),
                          SubArea: Text(ThisRecord.Value.SubArea),
                          Prioridad: Text(ThisRecord.Value.Prioridad),
                          Pais: Text(ThisRecord.Value.Pais),
                          AnalistaRol: Text(ThisRecord.Value.AnalistaRol),
                          Sociedad: Text(ThisRecord.Value.Sociedad),
                          Aprobacion: Text(ThisRecord.Value.Aprobacion),    
                          SLA: Value(ThisRecord.Value.SLA),
                          Estado: Text(ThisRecord.Value.EstadoActual),
                          Descripcion: Text(ThisRecord.Value.Descripcion),
                          VistoBueno: Text(ThisRecord.Value.VistoBueno),
                          CamposAdicionalesTicket: Text(ThisRecord.Value.CamposAdicionalesTicket),
                          Codigo: Text(ThisRecord.Value.Codigo),
                          TipoSolicitud: Text(ThisRecord.Value.TipoSolicitud),
                          CabeceraPaisSociedad: Text(ThisRecord.Value.CabeceraPaisSociedad)
                      }
                  )
              );

              // 4. Actualizar estados de navegación
              Set(
                  Var_HasNextSpvCatalogoServicio, 
                  (Var_CurrentPageSpvCatalogoServicio * Var_GridPageSizeSpvCatalogoServicio) < TotalItemSpvCatalogoServicio
              );
              Set(
                  Var_HasPrevSpvCatalogoServicio, 
                  Var_CurrentPageSpvCatalogoServicio > 1
              );
              UpdateContext({Var_SpvCtgLoadingSpinnerVisible: false})
            PressedBorderColor: =Self.Fill
            PressedColor: =Self.Fill
            PressedFill: =Self.Color
            Text: ="+"
            Visible: =false
            Width: =30
            X: =20
            Y: =20
