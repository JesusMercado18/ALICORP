alse,\n                    // Cálculo de altura dinámico (usando punto y coma)\n                    AlturaCampo: If(Text(_registro.Tipo) in [Var_JSONConfigurarTipoCampo.Texto, Var_JSONConfigurarTipoCampo.URL, Var_JSONConfigurarTipoCampo.Numerico], 60, \n                                    Text(_registro.Tipo) = Var_JSONConfigurarTipoCampo.Multiline, 80, \n                                    Text(_registro.Tipo) = Var_JSONConfigurarTipoCampo.Adjunto, 88, 60) \n                                 + If(IsBlank(Text(_registro.TextoGuia)), 0, 46),\n                    FechaReferencia: Today(),\n                    SelectorMesAño: false,\n                    ExcesoPesoDetectado: false,\n                    PermiteExcepcion: true,\n                    ValorExcepcion: false, // El estado del Toggle\n                    TextoExcepcion: \"\"   // El contenido del TextInput de justificación\n                }\n            )\n        )\n    );\n\n    // 2. SINCRONIZAR CON LA CONSOLIDADA\n    ClearCollect(colConsolidada, colFormularioDinamicoNuevoTicket);\n\n    // 3. REPARTO INICIAL EN GALERÍAS (ZIG-ZAG)\n    With(\n        { \n            _visiblesIniciales: Filter(\n                colConsolidada, \n                Visible && (IsBlank(DependeDe) || DependeDe = \"\")\n            ) \n        },\n        // Creamos la tabla temporal con índices\n        UpdateContext({\n            _tempConIndices: ForAll(\n                Sequence(CountRows(_visiblesIniciales)), \n                Patch(Index(_visiblesIniciales, Value), {PosicionVisual: Value})\n            )\n        });\n        \n        // Repartimos a las galerías finales\n        ClearCollect(GaleriaImpares, Filter(_tempConIndices, Mod(PosicionVisual, 2) <> 0));\n        ClearCollect(GaleriaPares, Filter(_tempConIndices, Mod(PosicionVisual, 2) = 0))\n    )\n);\n\nWith(\n    { _jsonTable: Table(ParseJSON(Trim(varTipoSolicitudSelected.CabeceraPaisSociedad))) },\n    ClearCollect(\n        colFormularioDinamicoCabeceraPaisSociedadNuevoTicket,\n        ForAll(\n            _jsonTable,\n            {\n                Etiqueta: Text(ThisRecord.Value.Etiqueta),\n                Obligatorio: Text(ThisRecord.Value.Obligatorio),\n                TipoCampo: Text(ThisRecord.Value.TipoCampo),\n                Visible: Boolean(ThisRecord.Value.Visible),\n                Varios: Boolean(ThisRecord.Value.Varios),\n                // Campo necesario para capturar la entrada del usuario en la App\n                ValorSeleccionado: \"\"\n            }\n        )\n    )\n);\n\nClearCollect(colDescargarPlantilla, Filter('LCP-001_Library_AdjuntosConfiguracion', CodigoConfiguracion = Text(varTipoSolicitudSelected.ID)))"
