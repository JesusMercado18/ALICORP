                                                                                                OnAddFile: "=// 1️⃣ Definir el límite y contexto\nSet(varLimiteSeccionBytes, Var_MaxAttachmentSize * 1024 * 1024);\nUpdateContext({ _idActual: ThisItem.ID, _labelActual: ThisItem.Label });\nClear(colErroresAdjuntos);\n\nForAll(\n    GalleryDerechaArchivos.AllItems As Fila, \n    With(\n        { _jsonRaw: JSON(Fila.Image8_1.Image, JSONFormat.IgnoreBinaryData) },\n        If(\n            IsBlank(LookUp(Var_uploadFile_listeAttachmentTicketDinamico As A, A.nombre = Fila.Name && A.label = _labelActual)),\n            With(\n                {\n                    extension: Lower(Last(Split(Fila.Name, \".\")).Value),\n                    base64Contenido: Mid(_jsonRaw, Find(\",\", _jsonRaw) + 1, Len(_jsonRaw) - Find(\",\", _jsonRaw) - 1)\n                },\n                With(\n                    { \n                        nuevoBytes: Len(base64Contenido) * 0.75, \n                        pesoActualSeccion: Sum(Filter(Var_uploadFile_listeAttachmentTicketDinamico, label = _labelActual), PesoBytes)\n                    },\n                    If(\n                        !(extension in [\"pdf\", \"doc\", \"docx\", \"xlsx\"]),\n                        Collect(colErroresAdjuntos, { Tipo: \"Formato\" }),\n\n                        // --- ERROR DE PESO ---\n                        (pesoActualSeccion + nuevoBytes) > varLimiteSeccionBytes,\n                        Concurrent(\n                            UpdateIf(colFormularioDinamicoNuevoTicket, ID = _idActual, { ExcesoPesoDetectado: true }),\n                            Collect(colErroresAdjuntos, { Tipo: \"TamanoSeccion\" })\n                        ),\n\n                        // --- ÉXITO ---\n                        \n                            Collect(\n                                Var_uploadFile_listeAttachmentTicketDinamico,\n                                {\n                                    nombre: Fila.Name,\n                                    contenido: base64Contenido,\n                                    PesoBytes: nuevoBytes,\n                                    label: _labelActual\n                                }\n                            );\n                            // Al subir uno correcto, evaluamos si el peso total acumulado ahora es legal\n                            UpdateIf(\n                                colFormularioDinamicoNuevoTicket, \n                                ID = _idActual, \n                                { ExcesoPesoDetectado: Sum(Filter(Var_uploadFile_listeAttachmentTicketDinamico, label = _labelActual), PesoBytes) > varLimiteSeccionBytes }\n                            )\n                        \n                    )\n                )\n            )\n        )\n    )\n);\n\n// --- CRITICAL: ACTUALIZACIÓN DE ALTURA Y SINCRONIZACIÓN ESPEJO ---\nWith(\n    { \n        _archivosDeEsteLabel: ShowColumns(Filter(Var_uploadFile_listeAttachmentTicketDinamico, label = _labelActual), nombre),\n        // CLAVE: Leemos el estado que dejó el ForAll directamente de la fila maestra\n        _registroMaestro: LookUp(colFormularioDinamicoNuevoTicket, ID = _idActual)\n    },\n    With(\n        {\n            // Usamos el estado que ya guardamos en el ForAll\n            _mostrarExcepcion: _registroMaestro.ExcesoPesoDetectado,\n            _altGal: If(CountRows(_archivosDeEsteLabel) > 3, 135, CountRows(_archivosDeEsteLabel) * 45)\n        },\n        With(\n            {\n                _nuevaAltura: 86 + _altGal + 10 + If(_mostrarExcepcion, 60, 0) + If(IsBlank(ThisItem.TextoGuia),0,46)\n            },\n            \n            // A. Actualizar la Maestra (solo la altura, el estado ya se puso arriba)\n            UpdateIf(\n                colFormularioDinamicoNuevoTicket,\n                ID = _idActual,\n                {\n                    ValorSeleccionad: If(IsEmpty(_archivosDeEsteLabel), Blank(), JSON(_archivosDeEsteLabel, JSONFormat.Compact)),\n                    AlturaCampo: _nuevaAltura\n                }\n            );\n\n            // B. Sincronizar Galerías de Vista\n            UpdateIf(GaleriaImpares, ID = _idActual, { \n                ValorSeleccionad: If(IsEmpty(_archivosDeEsteLabel), Blank(), JSON(_archivosDeEsteLabel, JSONFormat.Compact)),\n                AlturaCampo: _nuevaAltura, \n                ExcesoPesoDetectado: _mostrarExcepcion \n            });\n            \n            UpdateIf(GaleriaPares, ID = _idActual, { \n                ValorSeleccionad: If(IsEmpty(_archivosDeEsteLabel), Blank(), JSON(_archivosDeEsteLabel, JSONFormat.Compact)),\n                AlturaCampo: _nuevaAltura, \n                ExcesoPesoDetectado: _mostrarExcepcion \n            });\n            \n            ClearCollect(colConsolidada, colFormularioDinamicoNuevoTicket);\n            Select(btnRecalcularPosiciones)\n        )\n    )\n);\n\n// 4️⃣ Manejo de Errores\nSet(varMensajeError, \n    If(!IsBlank(LookUp(colErroresAdjuntos, Tipo = \"Formato\")), \"Formato no permitido.\",\n       !IsBlank(LookUp(colErroresAdjuntos, Tipo = \"TamanoSeccion\")), \"Límite de 25 MB excedido.\", \n       Blank())\n);\n\nIf(!IsBlank(varMensajeError), UpdateContext({ CloseAlert: true, Mensaje: varMensajeError }));\nReset(Self)"
