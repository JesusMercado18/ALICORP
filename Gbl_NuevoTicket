                                                                              OnChange: "=// 1. CAPTURA DE CONTEXTO E INICIALIZACIÓN\nUpdateContext({ \n    varReglaRota: Blank(), \n    varErrorMsg: Blank(), \n    _valorLimpio: Trim(Self.Text), // Limpiamos espacios una sola vez aquí\n    _idActual: ThisItem.ID,\n    _labelActual: ThisItem.Label\n});\n\n// 2. PROCESO DE VALIDACIÓN\nIf(\n    ThisItem.Regla,\n    UpdateContext({\n        varReglaRota: LookUp(\n            Split(ThisItem.DiccionarioRegla, \";\"), \n            With(\n                { _reglaDoc: LookUp('LCP-001_List_ConfigurarReglas', Codigo = Value && Estado = \"Activo\") },\n                !IsBlank(_reglaDoc.Codigo) && (\n                    ( _reglaDoc.TipoAccion = \"REGEX\" && !IsMatch(_valorLimpio, \"^[a-zA-Z0-9 ]*$\" ) ) ||\n                    ( _reglaDoc.TipoAccion = \"MAX_LENGTH\" && Len(_valorLimpio) > Value(_reglaDoc.Valor) ) ||\n                    ( _reglaDoc.TipoAccion = \"DECIMALS\" && (\n                        IsError(Value(_valorLimpio)) || \n                        (\",\" in _valorLimpio && Len(Last(Split(_valorLimpio, \",\")).Value) > Value(_reglaDoc.Valor))\n                    ))\n                )\n            )\n        )\n    })\n);\n\n// 3. EVALUACIÓN DE RESULTADOS\nIf(\n    !IsBlank(varReglaRota.Value),\n    \n    // --- CASO A: ERROR ---\n    \n        UpdateContext({ \n            varErrorMsg: LookUp('LCP-001_List_ConfigurarReglas', Codigo = varReglaRota.Value).Mensaje \n        });\n        Notify(\"Error: \" & varErrorMsg, NotificationType.Error)\n    ,\n\n    // --- CASO B: ÉXITO ---\n    \n        // A. ACTUALIZACIÓN DE VISTAS (Evita el borrado visual inmediato)\n        UpdateIf(GaleriaImpares, ID = _idActual, { ValorSeleccionad: _valorLimpio, Open: false });\n        UpdateIf(GaleriaPares, ID = _idActual, { ValorSeleccionad: _valorLimpio, Open: false });\n\n        // B. ACTUALIZACIÓN DE COLECCIÓN MAESTRA (Cerebro)\n        UpdateIf(\n            colFormularioDinamicoNuevoTicket,\n            ID = _idActual,\n            { \n                ValorSeleccionad: _valorLimpio, \n                Open: false \n            }\n        );\n\n        // C. LÓGICA DE AUTOCOMPLETADO / DEPENDENCIAS\n        If(\n            !IsBlank(_valorLimpio),\n            // Si el usuario escribió: Disparar Flow para hijos\n            With(\n                { _hijos: Filter(colFormularioDinamicoNuevoTicket, DependeDeAutocompletado = _labelActual) },\n                If(CountRows(_hijos) > 0,\n                    ForAll(\n                        _hijos As _itemHijo,\n                        With(\n                            { \n                                _resFlow: 'LCP-001_Flow_ObtenerRegistroAutocompletado'.Run(\n                                    _itemHijo.CatalogoAutocompletado,\n                                    _itemHijo.MostrarColumnaFiltrada,\n                                    _valorLimpio\n                                ).varrespuestaapi \n                            },\n                            Patch(\n                                colFormularioDinamicoNuevoTicket,\n                                _itemHijo,\n                                {\n                                    ValorEncontrado: _resFlow,\n                                    ValorSeleccionad: _resFlow\n                                }\n                            )\n                        )\n                    )\n                )\n            ),\n            // Si el usuario borró: Limpiar dependencias en la maestra\n            UpdateIf(\n                colFormularioDinamicoNuevoTicket,\n                DependeDeAutocompletado = _labelActual,\n                { ValorEncontrado: Blank() }\n            )\n        );\n\n        ClearCollect(colConsolidada, colFormularioDinamicoNuevoTicket);\n        // D. RECALCULAR POSICIONES (ZigZag dinámico)\n        // Solo llamamos a este botón una vez que todos los datos están asentados en la maestra\n        Select(btnRecalcularPosiciones)\n    \n)"
