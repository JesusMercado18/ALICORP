              )\n            )\n        )\n    })\n);\n\n// 4. EVALUACIÓN DE RESULTADO FINAL\nIf(\n    // CASO A: Error de SharePoint\n    !IsBlank(varReglaRota.Value),\n    \n        UpdateContext({ varErrorMsg: LookUp('LCP-001_List_ConfigurarReglas', Codigo = varReglaRota.Value).Mensaje });\n        Notify(\"Fecha no permitida: \" & varErrorMsg, NotificationType.Error)\n    ,\n\n    // CASO B: Error de cruce\n    varEsErrorCruzado,\n    Notify(varErrorMsg, NotificationType.Error),\n\n    // CASO C: TODO OK -> GUARDAR Y CERRAR\n    \n        // A. Actualizamos la Maestra (Cerebro)\n        UpdateIf(\n            colFormularioDinamicoNuevoTicket,\n            ID = var_RegistroFecha.ID, // Usamos ID por seguridad\n            {\n                ValorSeleccionad: Text(ThisItem.Value, \"yyyy-mm-dd\"),\n                Open: false,\n                AlturaCampo: (\n                    60 + If(IsBlank(var_RegistroFecha.TextoGuia), 0, 46)\n                )\n            }\n        );\n\n        // B. ESTRATEGIA DE APOYO: Sincronización de Galerías de Vista\n        // Actualizamos las colecciones espejo para que el calendario se cierre visualmente\n        UpdateIf(GaleriaImpares, ID = var_RegistroFecha.ID, { ValorSeleccionad: Text(ThisItem.Value, \"yyyy-mm-dd\"), Open: false, AlturaCampo: 60 + If(IsBlank(var_RegistroFecha.TextoGuia), 0, 46) });\n        UpdateIf(GaleriaPares, ID = var_RegistroFecha.ID, { ValorSeleccionad: Text(ThisItem.Value, \"yyyy-mm-dd\"), Open: false, AlturaCampo: 60 + If(IsBlank(var_RegistroFecha.TextoGuia), 0, 46) });\n\n        // C. CONSOLIDACIÓN Y RECÁLCULO\n        // Creamos el buffer y disparamos el zigzag para que los campos se reacomoden\n        ClearCollect(colConsolidada, colFormularioDinamicoNuevoTicket);\n        Select(btnRecalcularPosiciones)\n    \n)"
