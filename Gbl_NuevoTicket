           nombre: Fila.Name,\n                                contenido: base64Contenido,\n                                PesoBytes: nuevoBytes,\n                                Tipo: Label20_56.Text\n                            }\n                        )\n                    )\n                )\n            )\n        )\n    )\n);\n\n// 4️⃣ Mensaje de error (Límite de 25 MB)\nSet(\n    varMensajeError,\n    If(\n        !IsBlank(LookUp(colErroresAdjuntos, Tipo = \"Formato\")),\n        \"Formato no permitido. Solo se aceptan PDF, DOC, DOCX y XLSX.\",\n        !IsBlank(LookUp(colErroresAdjuntos, Tipo = \"Tamano\")),\n        \"El total de los archivos no puede superar los 25 MB.\",\n        Blank()\n    )\n);\n\nIf(\n    !IsBlank(varMensajeError),\n    UpdateContext({ CloseAlert: true, Mensaje: varMensajeError })\n);\n\nReset(Self)"
