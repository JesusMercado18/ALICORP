                      Pais: varPaisNuevoTicketSelected.Nombre,\r\n                        Sociedad: ValorSociedadLista,\r\n                        CabeceraPaisSociedad: JSON(ForAll(colFormularioDinamicoCabeceraPaisSociedadNuevoTicket, Patch(ThisRecord, { ValorSeleccionado: If(Etiqueta = \"País\", varPaisNuevoTicketSelected.Nombre, ValorSociedadConcat) })), JSONFormat.Compact),\r\n                        CamposAdicionalesTicket: JSON(colConsolidada, JSONFormat.Compact)\r\n                    })\r\n                );\r\n\r\n                Patch('LCP-001_List_TicketSolicitudes', { ID: Var_IdTicket.ID }, { FechaModificado: Var_IdTicket.FechaCreado, Codigo: \"TS_\" & Var_IdTicket.ID });\r\n\r\n\r\n                Concurrent('LCP-001_Flow_SubirAdjuntos'.Run(JSON(Var_uploadFile_listeAttachmentDatosAdjuntos), \"NUEVOTICKET\", Var_IdTicket.ID),\r\n                            'LCP-001_Flow_SubirAdjuntos'.Run(JSON(RenameColumns(Var_uploadFile_listeAttachmentTicketDinamico,label,Tipo)), \"DATOS DINAMICOS\", Var_IdTicket.ID));\r\n\r\n                // --- LIMPIEZA DE VARIABLES Y COLECCIONES ---\r\n\r\n                Clear(colConsolidada);\r\n                Clear(colFormularioDinamicoNuevoTicket);\r\n                Clear(colSociedadesMultiplesSeleccionadas);\r\n                Clear(Var_uploadFile_listeAttachmentDatosAdjuntos);\r\n                \r\n                UpdateContext({\r\n                    varGerenciaTipoSolicitudSelected: Blank(),\r\n                    varAreaTipoSolicitudSelected: Blank(),\r\n                    varSubAreaTipoSolicitudSelected: Blank(),\r\n                    varTipoSolicitudSelected: Blank(),\r\n                    varPaisNuevoTicketSelected: Blank(),\r\n                    varSociedadNuevoTicketSelected: Blank()\r\n                });\r\n                \r\n                Reset(TextInput3);\r\n\r\n                // Navegación con mensaje\r\n                Navigate(Sol_Ticket, Transition.None, { Var_Ctx_MensajeSatisfactorio: \"Ticket creado con éxito\" })\r\n                \r\n                \r\n                ,\r\n\r\n                // --- CASO ERROR: TU COMPONENTE ---\r\n\r\n                UpdateContext({ \r\n                CloseAlert: true, \r\n                Mensaje: If(\r\n                    !AgrupadoExiste, \r\n                    \"No existe un rol configurado para esta combinación de Gerencia, Área, País y Sociedad.\", \r\n                    !PaisOK,\r\n                    \"El campo País es obligatorio para esta configuración.\",\r\n                    !SociedadOK,\r\n                    \"El campo Sociedad es obligatorio o requiere selección múltiple.\",\r\n                    \"Por favor, complete los campos obligatorios marcados en rojo.\"\r\n                ) \r\n                });\r\n\r\n            // Si el error es en la galería, movemos la pantalla hacia ella\r\n            If(!CamposDinamicosOK, SetFocus(TextInput5) )\r\n\r\n            )\r\n        )\r\n    )\r\n)"
