ador: Coalesce(Campo.Condicion, \"=\") \r\n                },\r\n                    Switch(_operador,\r\n                        Var_JSONOperadores.Igual,  Trim(Lower(Text(_valPadre))) = Trim(Lower(Text(_valCondicion))),\r\n                        Var_JSONOperadores.Mayor,  Value(Coalesce(_valPadre, \"0\")) > Value(Coalesce(_valCondicion, \"0\")),\r\n                        Var_JSONOperadores.Menor,  Value(Coalesce(_valPadre, \"0\")) < Value(Coalesce(_valCondicion, \"0\")),\r\n                        Var_JSONOperadores.MayorIgual,  Value(Coalesce(_valPadre, \"0\")) >= Value(Coalesce(_valCondicion, \"0\")),\r\n                        Var_JSONOperadores.MenorIgual, Value(Coalesce(_valPadre, \"0\")) <= Value(Coalesce(_valCondicion, \"0\")),\r\n                        false\r\n                    )\r\n                )\r\n            )\r\n        )\r\n    ) && \r\n    (\r\n        // REGLA 3: Si cumple lo anterior, verificamos si está vacío (Error)\r\n        // Caso A: El valor principal está vacío y no hay excepción activada\r\n        (IsBlank(Trim(Text(Campo.ValorSeleccionad))) && !Campo.ValorExcepcion) ||\r\n        \r\n        // Caso B: Hay una excepción activada (ej. \"Otros\") pero el texto explicativo está vacío\r\n        (Campo.ValorExcepcion && IsBlank(Trim(Campo.TextoExcepcion)))\r\n    ),\r\n    { HasError: true }\r\n);\r\n\r\n\r\n// 2. CÁLCULO DE ESTADOS LOGICOS\r\nWith(\r\n    {\r\n        // Validación Cabecera Fija\r\n        BaseOK: \r\n            !IsBlank(varGerenciaTipoSolicitudSelected.Value) && \r\n            !IsBlank(varAreaTipoSolicitudSelected.Value) && \r\n            !IsBlank(varSubAreaTipoSolicitudSelected.Value) &&\r\n            !IsBlank(varRolAnalistaTipoSolicitudSelected.Value) &&  \r\n            !IsBlank(varTipoSolicitudSelected.TipoSolicitud),\r\n\r\n        // Validación Visto Bueno (Archivos)\r\n        /*\r\n        ArchivosOK: \r\n            If(\r\n                varTipoSolicitudSelected.VistoBueno;\r\n                CountR