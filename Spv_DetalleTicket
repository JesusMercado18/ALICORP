tado: FechaVencimientoEstado;\n                            //SLAEstado: Var_SLACalculado;\n                            ReApertura: Var_Ctx_Reactivar\n\n                        }\n                    ),\n                    //Caso switch 4\n                    Var_EstadosApp.EstadoCerrado,//Cierre excepcional\n                    Patch(\n                        'LCP-001_List_TicketSolicitudes',\n                        LookUp('LCP-001_List_TicketSolicitudes',ID = Var_SpvTicketSeleccionada.ID),\n                        {\n                            EstadoActual: Var_EstadosApp.EstadoCerrado,\n                            Motivo: Gbl_Confirmation_Update_5.ValorMotivo,\n                            MotivoObservacion: Gbl_Confirmation_Update_5.ValorOtro,\n                            FechaModificado: Now(),\n                            Accionador: \"Supervisor\",\n                            Evento: Var_EventoTrazabilidadApp.Estado,\n                            // Nuevo Analista\n                            NombreAtendidoPor: varUpdateAtendidoPorSelected.Nombre,\n                            CorreoAtendidoPor: varUpdateAtendidoPorSelected.Correo,\n                            // Analista anterior\n                            AtendidoNombreAnterior: Var_SpvTicketSeleccionada.NombreAtendidoPor,\n                            AtendidoCorreoAnterior: Var_SpvTicketSeleccionada.CorreoAtendidoPor,\n                            //FechaVencimientoEstado: FechaVencimientoEstado;\n                            //SLAEstado: Var_SLACalculado;\n                            ReApertura: false,\n                            Derivado: false,\n                            Rechazado: false,\n                            VistoBueno: false,\n                            VariosAprobadores: false,\n                            Aprobacion: false\n                        }\n                    )\n                ),\n                /* 3. MANEJO DE ERRORES (Si el Patch falla) */\n                Set(_varError, {\n                    Fecha: Now(),\n                    Usuario: {\n                        Codigo: Var_ProfileUser.Codigo,\n                        Nombre: Var_ProfileUser.NombreApellido\n                    },\n                    CodigoTicket: Var_SpvTicketSeleccionada.Codigo,\n                    Error: FirstError.Message\n                });\n                Patch('LCP-001_List_ErroresSolicitud', Defaults('LCP-001_List_ErroresSolicitud'), {\n                    TipoSolicitud: Var_TipoOperacionApp.Actualizar,\n                    FechaError: Now(),\n                    Error: JSON(_varError, JSONFormat.Compact),\n                    CodigoUsuario: Var_ProfileUser.Codigo\n                });\n                UpdateContext({ CloseAlert: true, Mensaje: \"Error al guardar: \" & FirstError.Message }),\n                /* 4. ÉXITO: CONTINUACIÓN SOLO SI NO HUBO ERROR */\n                If(\n                    !IsEmpty(Var_uploadFile_listeAttachment),\n                    'LCP-001_Flow_SubirAdjuntos'.Run(\n                        JSON(Var_uploadFile_listeAttachment),\n                        \"COMENTARIOS\",\n                        Text(Var_SpvTicketSeleccionada.ID)\n                    )\n                );\n                UpdateContext({Var_Ctx_ModalConfirmacion: false});\n                Navigate(\n                    Spv_Ticket,\n                    ScreenTransition.Fade,\n                    {\n                        AlertaSatisfactoria: true,\n                        MensajeSatisfactorio: \"Se actualizó el estado del ticket.\"\n                    }\n                )\n            ),\n//================CASO 2==================================\n        Var_EstadosApp.EstadoEnRevision,\n            /* 1. SI LAS VALIDACIONES PASAN, PROCEDEMOS */\n            IfError(\n                Switch(Var_Ctx_AccionEstado,\n                    //Caso switch 1\n                    Var_EstadosApp.EstadoRechazado,\n                    Patch(\n                        'LCP-001