n                colAprobadoresCheck,\n                AddColumns(\n                    ForAll(\n                        Table(ParseJSON(Trim(Var_SpvTicketSeleccionada.AprobadoresCheck))),\n                        {\n                            correo: Text(ThisRecord.Value.correo),\n                            nombre: Text(ThisRecord.Value.nombre),\n                            estado: Text(ThisRecord.Value.estado),\n                            fecha: Text(ThisRecord.Value.fecha)\n                        }\n                    ),\n                    FechaOrden,\n                    // Convertimos el texto a DateTime asumiendo un formato de fecha local. \n                    // Si la fecha viene vacía desde el JSON, asignamos Blank().\n                    If(IsBlank(fecha) Or Len(fecha) < 8, Blank(), DateTimeValue(fecha, \"es-ES\"))\n                )\n            );\n            // 2. Aislamiento del registro y actualización estructurada\n            With(\n                {\n                    varTargetRecord: First(\n                        Sort(\n                            Filter(\n                                colAprobadoresCheck,\n                                correo = Var_ProfileUser.CorreoUsuario && IsBlank(estado)\n                            ),\n                            FechaOrden,\n                            SortOrder.Descending\n                        )\n                    )\n                },\n                // 3. Verificamos que el registro haya sido encontrado antes de aplicar Patch\n                If(\n                    !IsBlank(varTargetRecord.correo),\n                    Patch(\n                        colAprobadoresCheck,\n                        varTargetRecord,\n                        {\n                            estado: \"Rechazado\",\n                            fecha: Text(Now(), \"dd/mm/yyyy hh:mm:ss\")\n                        }\n                    )\n                )\n            );\n            /* 1. SI LAS VALIDACIONES PASAN, PROCEDEMOS */\n            IfError(\n                Switch(Var_Ctx_AccionEstado,\n                    //Caso switch 1\n                    Var_EstadosApp.EstadoRechazado,\n                    Patch(\n                        'LCP-001_List_TicketSolicitudes',\n                        LookUp('LCP-001_List_TicketSolicitudes',ID = Var_SpvTicketSeleccionada.ID),\n                        {\n                            EstadoActual: Var_EstadosApp.EstadoEnProceso,\n                            Motivo: Gbl_Confirmation_Update_5.ValorMotivo,\n                            MotivoObservacion: Gbl_Confirmation_Update_5.ValorOtro,\n                            Comentario: Spv_RichComentariosDetalleTicket.HtmlText,\n                            FechaModificado: Now(),\n                            Accionador: \"Supervisor\",\n                            Evento: Var_EventoTrazabilidadApp.Estado,\n                            AprobadoresCheck: JSON(colAprobadoresCheck,JSONFormat.Compact)\n                        }\n                    ),\n                    //Caso switch 2\n                    Var_EstadosApp.EstadoDerivado,\n                    Patch(\n                        'LCP-001_List_TicketSolicitudes',\n                        LookUp('LCP-001_List_TicketSolicitudes',ID = Var_SpvTicketSeleccionada.ID),\n                        {\n                            EstadoActual: If(IsBlank(varUpdateAtendidoPorSelected), varEstadoSelected.Value, Var_EstadosApp.EstadoEnRevision),\n                            Motivo: Gbl_Confirmation_Update_5.ValorMotivo,\n                            MotivoObservacion: Gbl_Confirmation_Update_5.ValorOtro,\n                            Comentario: Spv_RichComentariosDetalleTicket.HtmlText,\n                            FechaModificado: Now(),\n                            Accionador: \"Supervisor\",\n                            Evento: Var_EventoTrazabilidadApp.Estado,\n                            // Nuevo Analista\n                            NombreA