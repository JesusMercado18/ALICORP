    Properties:
      LoadingSpinnerColor: =RGBA(56, 96, 178, 1)
      OnVisible: "=Reset(Spv_RichComentariosDetalleTicket);\nClear(Var_uploadFile_listeAttachment);\nSet(\n    Var_EstadoTicketSeleccionado,\n    Var_SpvTicketSeleccionada.Estado\n);\nUpdateContext(\n    {\n        varEstadoSelected: Blank(),\n        varGerenciaSelected: Blank(),\n        varUpdateAreaSelected: Blank(),\n        varUpdateSubAreaSelected: Blank(),\n        varUpdatePaisSelected: Blank(),\n        varUpdateSociedadSelected: Blank(),\n        varUpdateAtendidoPorSelected: Blank(),\n        varUpdateAnteriorNombreAtendidoPorSelected: Blank(),\n        varUpdateAnteriorCorreoAtendidoPorSelected: Blank(),\n        varUpdateMotivoDerivacionSelected: Blank()\n    }\n);\nUpdateContext({Var_Ctx_ModalConfirmacion: false});\nUpdateContext(\n    {\n        varOpenDropDownEstadoTransicion: false,\n        varOpenDropDownGerencia: false,\n        varOpenDropDownUpdateArea: false,\n        varOpenDropDownUpdateSubArea: false,\n        varOpenDropDownUpdateSociedad: false,\n        varOpenDropDownUpdateAtendidoPor: false,\n        varOpenDropDownUpdateMotivoDerivacion: false\n    }\n);\nClear(colUpdateGerenciaSpv);\nClear(colUpdateAreaSpv);\nClear(colUpdateSubAreaSpv);\nClear(colUpdatePaisSpv);\nClear(colUpdateSociedadSpv);\nClear(colUpdateAtendidoPorSpv);\nUpdateContext({menuSelected: 3});\nClearCollect(\n    colTrackingTicketsSpv,\n    Filter(\n        'LCP-001_List_TrackingTicketSolicitud',\n        Codigo = Text(Var_SpvTicketSeleccionada.Codigo)\n    )\n);\nClear(colDiscusionTicketSpv);\nForAll(\n    Filter(\n        colTrackingTicketsSpv,\n        Len(Trim(PlainText(Comentario))) > 0\n    ) As TrackingTicket,\n    Collect(\n        colDiscusionTicketSpv,\n        {\n            Image: TrackingTicket.'Creado por'.Picture,\n            UserName: TrackingTicket.'Creado por'.DisplayName,\n            FechaCreado: TrackingTicket.FechaModificado,\n            Comentario: TrackingTicket.Comentario\n        }\n    )\n);\n/*\nClearCollect(colDiscusionTicketSpv;{ Image: User().Image ; UserName: \"Dmartin\" ; FechaCreado: Now() ; Comentario : \"Lorem ipsum dolor sit amet consectetur.\"};{ Image: User().Image ; UserName: \"Ljuan\" ; FechaCreado: Now() ; Comentario : \"Lorem ipsum dolor sit amet consectetur.\"} );;\n*//*\nClearCollect(colCambiosTicketSpv; { Image: User().Image ; UserName: \"Dmartin\" ; Fecha : Now() ; Accion: \"Asignar\" } ; { Image: User().Image ; UserName: \"Ljuan\" ; Fecha : Now() ; Accion: \"Prioridad\" }  ; { Image: User().Image ; UserName: \"Ljuan\" ; Fecha : Now() ; Accion: \"Estado\" ; Estado: \"En proceso\"});;\n*/UpdateContext({datosAdjuntos: 'LCP-001_Flow_ObtenerAdjuntos'.Run(Text(Var_SpvTicketSeleccionada.ID))});\nIf(\n    datosAdjuntos.response = \"200\",\n    Clear(colAdjuntosDetalleTicket);\n    ForAll(\n        Table(ParseJSON(datosAdjuntos.datosadjuntos)),\n        Collect(\n            colAdjuntosDetalleTicket,\n            {\n                Nombre: Text(ThisRecord.Value.Nombre),\n                PesoBytes: Value(ThisRecord.Value.PesoBytes),\n                Url: Text(ThisRecord.Value.Url),\n                TipoAdjunto: Text(ThisRecord.Value.TipoAdjunto)\n            }\n        )\n    )\n);\nSet(\n    varBytesExistentes,\n    Sum(\n        colAdjuntosDetalleTicket,\n        PesoBytes\n    )\n);\nClearCollect(\n    colCambiosTicketSpv,\n    colTrackingTicketsSpv\n);\n\nClearCollect(\n    colTransicionEstadoSpv,\n    Switch(\n        Text(Var_SpvTicketSeleccionada.Estado),\n        //Caso switch 1\n        Var_EstadosApp.EstadoEnRevision,\n        [\n            Var_EstadosApp.EstadoEnProceso,\n            Var_EstadosApp.EstadoObservado,\n            Var_EstadosApp.EstadoDerivado,\n            Var_EstadosApp.EstadoCerrado\n        ],\n        //Caso switch 2\n        Var_EstadosApp.EstadoCerrado,\n        [\"\"],\n        //Caso switch 3\n        Var_EstadosApp.EstadoEnProceso,\n        [\n            Var_EstadosApp.EstadoResuelto,\n            Var_EstadosApp.EstadoEnEsperaAprobacion\n        ],\n        //Caso switch 4\n        Var_EstadosApp.EstadoRechazado,\n        [\"\"],\n        //Caso switch 5\n        Var_EstadosApp.EstadoObservado,\n        [\n            Var_EstadosApp.EstadoEnRevision,\n            Var_EstadosApp.EstadoCerrado\n        ],\n        //Caso switch 6\n        Var_EstadosApp.EstadoEnEsperaAprobacion,\n        [\n            Var_EstadosApp.EstadoEnProceso\n        ],\n        //Caso switch 7\n        Var_EstadosApp.EstadoResuelto,\n        [Var_EstadosApp.EstadoCerrado],\n        //Caso switch 8\n        Var_EstadosApp.EstadoDerivado,\n        [\"\"]\n    )\n);\n\nClearCollect(\n    colAreasSpv,\n    [\n        \"Administración de personal\",\n        \"Cobranzas\",\n        \"Créditos BackOffice\",\n        \"Cuentas por pagar\",\n        \"Gestión comercial\",\n        \"Nómina\",\n        \"Nuevos servicios\",\n        \"Seguros\",\n        \"Tesorería operativa\"\n    ]\n);\nClearCollect(\n    colUsuarios,\n    [\n        \"JJulian\",\n        \"DMario\"\n    ]\n);\nClearCollect(\n    colAsignarSLA,\n    [3]\n);\nClearCollect(\n    colMotivoDerivacionSpv,\n    [\n        \"Especialización técnica\",\n        \"Capacidad\",\n        \"Nivel de autorización\",\n        \"Error de asignación\",\n        \"Dependencia externa\",\n        \"Otro\"\n    ]\n);\n// Campos desde la configuración del ticket\n// Paso 1: Guardamos el JSON crudo\nUpdateContext(\n    {\n        Var_Ctx_ConfiguracionPaisSociedad: LookUp(\n            'LCP-001_List_Configuracion_Ticket',\n            Codigo = Text(Var_SpvTicketSeleccionada.ConfiguracionTicket),\n            CabeceraPaisSociedad\n        )\n    }\n);\nClear(Col_ConfiguracionTablaSpv);\nForAll(\n    Table(ParseJSON(Var_Ctx_ConfiguracionPaisSociedad)),\n    Collect(\n        Col_ConfiguracionTablaSpv,\n        {\n            Etiqueta: Text(ThisRecord.Value.Etiqueta),\n            Obligatorio: Boolean(ThisRecord.Value.Obligatorio)\n        }\n    )\n);\n// Paso 2: Parseamos el JSON UNA SOLA VEZ y extraemos Obligatorio\nUpdateContext(\n    {\n        Var_Ctx_PaisObligatorio: LookUp(\n            Col_ConfiguracionTablaSpv,\n            ThisRecord.Etiqueta = \"País\",\n            ThisRecord.Obligatorio\n        ),\n        Var_Ctx_SociedadObligatorio: LookUp(\n            Col_ConfiguracionTablaSpv,\n            ThisRecord.Etiqueta = \"Sociedad\",\n            ThisRecord.Obligatorio\n        )\n    }\n);\n//Var_SpvTicketSeleccionada\nClearCollect(\n    colUpdateGerenciaSpv,\n    [Text(Var_SpvTicketSeleccionada.Gerencia)]\n);\nUpdateContext({varGerenciaSelected: {Value: Text(Var_SpvTicketSeleccionada.Gerencia)}});\n//Set(varGerenciaSelected; { Value: Text(Var_SpvTicketSeleccionada.Gerencia) });;\nUpdateContext({varUpdateAreaSelected: {Area: Text(Var_SpvTicketSeleccionada.Area)}});\n// varUpdateSubAreaSelected\nUpdateContext({varUpdateSubAreaSelected: {SubArea: Text(Var_SpvTicketSeleccionada.SubArea)}});\nUpdateContext(\n    {\n        varUpdateAtendidoPorSelected: {\n            Nombre: Text(Var_SpvTicketSeleccionada.AnalistaNombre),\n            Correo: Text(Var_SpvTicketSeleccionada.AnalistaCorreo)\n        }\n    }\n);\nUpdateContext({varUpdateAnteriorNombreAtendidoPorSelected: {NombreAnterior: Text(Var_SpvTicketSeleccionada.AnalistaNombre)}});\nUpdateContext({varUpdateAnteriorCorreoAtendidoPorSelected: {CorreoAnterior: Text(Var_SpvTicketSeleccionada.AnalistaCorreo)}});\nIf(\n    !IsBlank(Var_SpvTicketSeleccionada.MotivoDerivacion),\n    UpdateContext({varUpdateMotivoDerivacionSelected: Blank()});\n    //{ Value : Text(Var_SpvTicketSeleccionada.MotivoDerivacion) }\n    \n);\nClearCollect(\n    colUpdateAreaSpv,\n    Filter(\n        'LCP-001_List_GerenciaArea',\n        Gerencia = Text(Var_SpvTicketSeleccionada.Gerencia) && Area = Text(Var_SpvTicketSeleccionada.Area)\n    ).Area\n//Distinct(Filter('LCP-001_List_Configuracion_Ticket'; Gerencia = Text(Var_SpvTicketSeleccionada.Gerencia)  );Area) \n);\nClearCollect(\n    colAreaSubAreaLocalSpv,\n    'LCP-001_List_AreaSubArea'\n);\nClearCollect(\n    colUpdateSubAreaSpv,\n    Filter(\n        colAreaSubAreaLocalSpv,\n        Area in colUpdateAreaSpv.Area\n    ).SubArea\n);\nUpdateContext({varUpdatePaisSelected: {Value: Text(Var_SpvTicketSeleccionada.Pais)}});\nUpdateContext({varUpdateSociedadSelected: {Sociedad: Text(Var_SpvTicketSeleccionada.Sociedad)}});\nClearCollect(\n    colPaisSociedadLocalSpv,\n    'LCP-001_List_PaisSociedad'\n);\nIf(\n    Text(Var_SpvTicketSeleccionada.SubArea) in [\n        \"Nóminas Perú\",\n        \"Nóminas Países\"\n    ],\n    ClearCollect(\n        colUpdatePaisSpv,\n        Filter(\n            'LCP-001_List_PaisSubArea',\n            SubArea = Text(Var_SpvTicketSeleccionada.SubArea)\n        ).Pais\n    );\n    ClearCollect(\n        colUpdateSociedadSpv,\n        Filter(\n            colPaisSociedadLocalSpv,\n            Pais in colUpdatePaisSpv.Pais\n        ).Sociedad\n    ),\n    ClearCollect(\n        colUpdatePaisSpv,\n        Distinct(\n            colPaisSociedadLocalSpv,\n            Pais\n        )\n    );\n    //ClearCollect(colUpdateSociedadSpv; Filter(colPaisSociedadLocalSpv; Pais in  colUpdatePaisSpv.Value).Sociedad)\n    \n);\nIf(\n    LookUp(\n        'LCP-001_List_Usuarios',\n        CorreoUsuario = varUpdateAtendidoPorSelected.Correo,\n        Estado\n    ) = \"Activo\",\n    Set(\n        VarReactivacion,\n        true\n    ),\n    Set(\n        VarReactivacion,\n        false\n    )\n);\n// 1. Evaluación defensiva del estado del Ticket y la cadena JSON\nIf(\n    !IsBlank(Var_SpvTicketSeleccionada) And \n    !IsBlank(Var_SpvTicketSeleccionada.AprobadoresCheck) And \n    Len(Trim(Text(Var_SpvTicketSeleccionada.AprobadoresCheck))) > 2, // > 2 previene cadenas vacías o corchetes sin datos '[]'\n    \n    // 2. Ejecución segura del ParseJSON si la evaluación es verdadera\n    ClearCollect(\n        colAprobadoresCheck,\n        AddColumns(\n            ForAll(\n                Table(ParseJSON(Trim(Var_SpvTicketSeleccionada.AprobadoresCheck))),\n                {\n                    correo: Text(ThisRecord.Value.correo),\n                    nombre: Text(ThisRecord.Value.nombre),\n                    estado: Text(ThisRecord.Value.estado),\n                    fecha: Text(ThisRecord.Value.fecha)\n                }\n            ),\n            FechaOrden,\n            // Convertimos el texto a DateTime asumiendo un formato de fecha local.\n            If(IsBlank(fecha) Or Len(fecha) < 8, Blank(), DateTimeValue(fecha, \"es-ES\"))\n        )\n    ),\n    \n    // 3. Fallback: Si no hay ticket o el JSON viene vacío, se limpia la colección.\n    // Esto asegura que la UI no colapse ni muestre datos fantasma.\n    Clear(colAprobadoresCheck)\n);\n//Distinct(Filter('LCP-001_List_Configuracion_Ticket'; Gerencia = Text(Var_SpvTicketSeleccionada.Gerencia) && Area = Text(Var_SpvTicketSeleccionada.Area)  );SubArea) \n/*\nSet(Var_RolSpv;\n     LookUp(\n        'LCP-001_List_RolGerenciaAreaSubAreaPaisSoc';\n        Gerencia = Text(Var_SpvTicketSeleccionada.Gerencia) &&\n        Area = Text(Var_SpvTicketSeleccionada.Area) &&\n        SubArea = Text(Var_SpvTicketSeleccionada.SubArea) &&\n        Pais = Text(Var_SpvTicketSeleccionada.Pais) && \n        Sociedad = Text(Var_SpvTicketSeleccionada.Sociedad)\n    ).RolGeneralNombre);;        \nClearCollect(colAgrupadorSupervisor; Filter('LCP-001_List_AgrupadorAnalistas'; RolCompuestoAnalista  = Var_RolSpv));;\nClear(colUpdateAtendidoPorSpv);;\nForAll(\n    colAgrupadorSupervisor;\n    With(\n        {\n            _usr: LookUp(\n                'LCP-001_List_Usuarios';\n                CorreoUsuario = Usuario\n            )\n        };\n        If(\n            !IsBlank(_usr);\n            Collect(\n                colUpdateAtendidoPorSpv;\n                {\n                    Correo: _usr.CorreoUsuario;\n                    Nombre: _usr.NombreApellido\n                }\n            )\n        )\n    )\n)\n*/\n"
