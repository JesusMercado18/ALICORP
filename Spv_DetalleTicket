                  Guardar: "=/* 1. VALIDACIONES INICIALES */\nIf(\n    (Gbl_Confirmation_Update_5.ValorMotivo = \"Otro\" && IsBlank(Trim(Gbl_Confirmation_Update_5.ValorOtro))) ||\n    IsBlank(Gbl_Confirmation_Update_5.ValorMotivo),\n    \n    UpdateContext({\n        CloseAlert: true,\n        Mensaje: If(IsBlank(Gbl_Confirmation_Update_5.ValorMotivo), \"Debes seleccionar el motivo\", \"Debes ingresar el motivo.\")\n    }),\n    //Si el boton Var_Ctx_BtnReasignar es true se hace la logica que estaba en el boton, de caso contrario se hacen los demas casos\n    If(Var_Ctx_BtnReasignar,\n    //Logica If true\n            If(\n            IsBlank(varGerenciaSelected.Value),\n                UpdateContext({ CloseAlert: true, Mensaje: \"Debes ingresar la Gerencia.\" }),\n        \n            IsBlank(varUpdateAreaSelected.Area),\n                UpdateContext({ CloseAlert: true, Mensaje: \"Debes ingresar el Área.\" }),\n        \n            IsBlank(varUpdateSubAreaSelected.SubArea),\n                UpdateContext({ CloseAlert: true, Mensaje: \"Debes ingresar la SubÁrea.\" }),\n        \n            Var_Ctx_PaisObligatorio && IsBlank(varUpdatePaisSelected.Value),\n                UpdateContext({ CloseAlert: true, Mensaje: \"Debes ingresar el País.\" }),\n        \n            Var_Ctx_SociedadObligatorio && IsBlank(varUpdateSociedadSelected.Sociedad),\n                UpdateContext({ CloseAlert: true, Mensaje: \"Debes ingresar la Sociedad.\" }),\n            \n            !(Spv_LblEstadoActualDetalleTicket.Text in [Var_EstadosApp.EstadoEnRevision, Var_EstadosApp.EstadoDerivado, Var_EstadosApp.EstadoObservado, Var_EstadosApp.EstadoEnProceso, Var_EstadosApp.EstadoEnEsperaAprobacion]),\n                UpdateContext({ CloseAlert: true, Mensaje: \"El estado actual (\" & Spv_LblEstadoActualDetalleTicket.Text & \") no permite actualizar el ticket.\" }),\n        \n            IfError(\n            \n                // \U0001F539 SOLO el Patch aquí\n                Patch(\n      