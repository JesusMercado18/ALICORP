                                                                        OnSelect: "=//Se calcula el valor que toma el SLA del estado\r\nIf(\r\n\r\nIsEmpty(Filter('LCP-001_List_EstadosProceso',ConfiguracionTicket = Var_SpvTicketSeleccionada.ConfiguracionTicket)),\r\nUpdateContext({Var_SLACalculado: 0, FechaVencimientoEstado: Var_SpvTicketSeleccionada.FechaVencimiento}),\r\n\r\nIf(\r\nIsBlank(varEstadoSelected.Value),  \r\nUpdateContext({ CloseAlert: true, Mensaje: \"Debes seleccionar un estado.\" }), \r\nSwitch(\r\n    varEstadoSelected.Value,\r\n    //Caso Switch\r\n    Var_EstadosApp.EstadoObservado,\r\n    \r\n    With(\r\n    {\r\n        auxSLA: LookUp('LCP-001_List_EstadosProceso', EstadoActual = Var_EstadosApp.EstadoObservado && EstadoSiguiente = Var_EstadosApp.EstadoEnRevision).SLA\r\n\r\n    },\r\n    UpdateContext({Var_SLACalculado: If(Or(IsBlank(auxSLA), auxSLA = 0 ), 0, If( Value(Spv_TxtAsignarSLATiempoAtencionDetalleTicket.Text) <>  auxSLA, Value(Spv_TxtAsignarSLATiempoAtencionDetalleTicket.Text), auxSLA))    });\r\n\r\n    If(\r\n    Var_SLACalculado = 0,\r\n    0, \r\n    // Calculamos la fecha de vencimiento del SLA para insertarlo en Tracking\r\n    ClearCollect( colFechas, AddColumns( Sequence(Var_SLACalculado * 3), Fecha, DateAdd(Now(), Value, TimeUnit.Days) ) ); \r\n    ClearCollect( colDiasHabiles, FirstN( Filter( colFechas, Weekday(Fecha, StartOfWeek.Monday) <= 5 && IsBlank( LookUp( colFeriados, FechaCompleta = Fecha ) ) ), Var_SLACalculado))\r\n    );\r\n\r\n    UpdateContext({FechaVencimientoEstado: If(Var_SLACalculado = 0 , Var_SpvTicketSeleccionada.FechaVencimiento, Last(colDiasHabiles).Fecha)})\r\n    )\r\n    ,\r\n\r\n\r\n    //Caso Switch\r\n    //1.Si no hay analista asignado -> No hay modificacion se encarga el balanceador\r\n    //2.Si hay analista seleccionado -> Busco el SLA en revisión \r\n\r\n    Var_EstadosApp.EstadoDerivado,\r\n    \r\n    With(\r\n    {\r\n        auxSLA: LookUp('LCP-001_List_EstadosProceso', EstadoActual = Var_EstadosApp.EstadoEnRevision && EstadoSiguiente = Blank()).SLA\r\n    },\r\n\r\n    UpdateContext({Var_SLACalculado: If(Or(IsBlank(auxSLA), auxSLA = 0 ), 0, auxSLA)});\r\n    If(\r\n    Var_SLACalculado = 0,\r\n    0, \r\n    // Calculamos la fecha de vencimiento del SLA para insertarlo en Tracking\r\n    ClearCollect( colFechas, AddColumns( Sequence(auxSLA * 3), Fecha, DateAdd(Now(), Value, TimeUnit.Days) ) ); \r\n    ClearCollect( colDiasHabiles, FirstN( Filter( colFechas, Weekday(Fecha, StartOfWeek.Monday) <= 5 && IsBlank( LookUp( colFeriados, FechaCompleta = Fecha ) ) ), auxSLA))\r\n    );\r\n    UpdateContext({FechaVencimientoEstado: If( Var_SLACalculado = 0, Var_SpvTicketSeleccionada.FechaVencimiento, Last(colDiasHabiles).Fecha)})\r\n    )\r\n\r\n    ,\r\n    //Caso Switch\r\n    Var_EstadosApp.EstadoEnProceso,\r\n    true\r\n    ,\r\n    //Caso Switch\r\n    Var_EstadosApp.EstadoEnEsperaAprobacion,\r\n    \r\n\r\n    With(\r\n    {\r\n        auxSLA: LookUp('LCP-001_List_EstadosProceso', EstadoActual = Var_EstadosApp.EstadoEnEsperaAprobacion && EstadoSiguiente = Var_EstadosApp.EstadoEnProceso).SLA\r\n    },\r\n\r\n    UpdateContext({Var_SLACalculado: If(Or(IsBlank(auxSLA), auxSLA = 0 ), 0, auxSLA)});\r\n    If(\r\n    Var_SLACalculado = 0,\r\n    0, \r\n    // Calculamos la fecha de vencimiento del SLA para insertarlo en Tracking\r\n    ClearCollect( colFechas, AddColumns( Sequence(auxSLA * 3), Fecha, DateAdd(Now(), Value, TimeUnit.Days) ) ); \r\n    ClearCollect( colDiasHabiles, FirstN( Filter( colFechas, Weekday(Fecha, StartOfWeek.Monday) <= 5 && IsBlank( LookUp( colFeriados, FechaCompleta = Fecha ) ) ), auxSLA))\r\n    );\r\n    UpdateContext({FechaVencimientoEstado: If( Var_SLACalculado = 0, Var_SpvTicketSeleccionada.FechaVencimiento, Last(colDiasHabiles).Fecha)})\r\n    )\r\n\r\n    ,\r\n    //Caso Switch\r\n    Var_EstadosApp.EstadoResuelto,\r\n    true\r\n    ,\r\n    //Caso Switch\r\n    Var_EstadosApp.EstadoEnRevision,\r\n    true\r\n)\r\n)\r\n);\r\n\