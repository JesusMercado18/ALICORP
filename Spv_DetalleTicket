        // Paso 2: Parseamos el JSON UNA SOLA VEZ y extraemos Obligatorio
        UpdateContext({
            Var_Ctx_PaisObligatorio: LookUp(Col_ConfiguracionTablaSpv, ThisRecord.Etiqueta = "País",ThisRecord.Obligatorio),
            Var_Ctx_SociedadObligatorio: LookUp(Col_ConfiguracionTablaSpv, ThisRecord.Etiqueta = "Sociedad",ThisRecord.Obligatorio)
        });


        //Var_SpvTicketSeleccionada

        ClearCollect(colUpdateGerenciaSpv,[Text(Var_SpvTicketSeleccionada.Gerencia)]);

        UpdateContext({ varGerenciaSelected : { Value: Text(Var_SpvTicketSeleccionada.Gerencia) } });
        //Set(varGerenciaSelected; { Value: Text(Var_SpvTicketSeleccionada.Gerencia) });;

        UpdateContext({ varUpdateAreaSelected : { Area: Text(Var_SpvTicketSeleccionada.Area) } });

        // varUpdateSubAreaSelected

        UpdateContext({ varUpdateSubAreaSelected : { SubArea: Text(Var_SpvTicketSeleccionada.SubArea) } });

        UpdateContext({ varUpdateAtendidoPorSelected : { Nombre: Text(Var_SpvTicketSeleccionada.AnalistaNombre), Correo: Text(Var_SpvTicketSeleccionada.AnalistaCorreo) } });

        UpdateContext({ varUpdateAnteriorNombreAtendidoPorSelected : { NombreAnterior: Text(Var_SpvTicketSeleccionada.AnalistaNombre) } });
        UpdateContext({ varUpdateAnteriorCorreoAtendidoPorSelected : { CorreoAnterior: Text(Var_SpvTicketSeleccionada.AnalistaCorreo) } });

        If(!IsBlank(Var_SpvTicketSeleccionada.MotivoDerivacion),
        UpdateContext({ varUpdateMotivoDerivacionSelected : Blank() }); //{ Value : Text(Var_SpvTicketSeleccionada.MotivoDerivacion) }
        );

        ClearCollect(colUpdateAreaSpv, 

        Filter('LCP-001_List_GerenciaArea', Gerencia = Text(Var_SpvTicketSeleccionada.Gerencia) && Area = Text(Var_SpvTicketSeleccionada.Area)).Area

        //Distinct(Filter('LCP-001_List_Configuracion_Ticket'; Gerencia = Text(Var_SpvTicketSeleccionada.Gerencia)  );Area) 

        );

        ClearCollect(
            colAreaSubAreaLocalSpv,
            'LCP-001_List_AreaSubArea'
        );

        ClearCollect(
            colUpdateSubAreaSpv,
            Filter(
                colAreaSubAreaLocalSpv,
                Area in colUpdateAreaSpv.Area
            ).SubArea
        );


        UpdateContext({ varUpdatePaisSelected : { Value: Text(Var_SpvTicketSeleccionada.Pais) } });
        UpdateContext({ varUpdateSociedadSelected : { Sociedad: Text(Var_SpvTicketSeleccionada.Sociedad) } });


        ClearCollect(colPaisSociedadLocalSpv, 'LCP-001_List_PaisSociedad');

        If(Text(Var_SpvTicketSeleccionada.SubArea) in ["Nóminas Perú","Nóminas Países"],

        ClearCollect(colUpdatePaisSpv, Filter('LCP-001_List_PaisSubArea',SubArea =  Text(Var_SpvTicketSeleccionada.SubArea)).Pais);

        ClearCollect(colUpdateSociedadSpv, Filter(colPaisSociedadLocalSpv, Pais in colUpdatePaisSpv.Pais).Sociedad),

        ClearCollect(colUpdatePaisSpv, Distinct(colPaisSociedadLocalSpv,Pais));

        //ClearCollect(colUpdateSociedadSpv; Filter(colPaisSociedadLocalSpv; Pais in  colUpdatePaisSpv.Value).Sociedad)

        );
        If(LookUp('LCP-001_List_Usuarios', CorreoUsuario = varUpdateAtendidoPorSelected.Correo, Estado) = "Activo",Set(VarReactivacion,true),Set(VarReactivacion,false))

        //Distinct(Filter('LCP-001_List_Configuracion_Ticket'; Gerencia = Text(Var_SpvTicketSeleccionada.Gerencia) && Area = Text(Var_SpvTicketSeleccionada.Area)  );SubArea) 



        /*
        Set(Var_RolSpv;
             LookUp(
                RolGerenciaAreaSubAreaPaisSoc;
                Gerencia = Text(Var_SpvTicketSeleccionada.Gerencia) &&
                Area = Text(Var_SpvTicketSeleccionada.Area) &&
                SubArea = Text(Var_SpvTicketSeleccionada.SubArea) &&
                Pais = Text(Var_SpvTicketSeleccionada.Pais) && 
                Sociedad = Text(Var_SpvTicketSeleccionada.Sociedad)
            ).RolGeneralNombre);;        

        ClearCollect(colAgrupadorSupervisor; Filter('LCP-001_List_AgrupadorAnalistas'; RolCompuestoAnalista  = Var_RolSpv));;

        Clear(colUpdateAtendidoPorSpv);;

        ForAll(
            colAgrupadorSupervisor;
            With(
                {
                    _usr: LookUp(
                        'LCP-001_List_Usuarios';
                        CorreoUsuario = Usuario
                    )
                };
                If(
                    !IsBlank(_usr);
                    Collect(
                        colUpdateAtendidoPorSpv;
                        {
                            Correo: _usr.CorreoUsuario;
                            Nombre: _usr.NombreApellido
                        }
                    )
                )
            )
        )

        */


