                                                                                                    !IsBlank(LookUp(colErroresAdjuntos, Tipo = "Cantidad")),
                                                                                                    "Se alcanzó el número máximo de archivos permitidos.",
                                                                                                    !IsBlank(LookUp(colErroresAdjuntos, Tipo = "Tamano")),
                                                                                                    "El tamaño total de los archivos no puede superar los " & Self.MaxAttachmentSize & " MB.",
                                                                                                    Blank()
                                                                                                )
