    Properties:
      LoadingSpinnerColor: =RGBA(56, 96, 178, 1)
      OnVisible: |+
        =Reset(Spv_RichComentariosDetalleTicket);
        Clear(Var_uploadFile_listeAttachmentSpv);
        Set(Var_EstadoTicketSeleccionado,Var_SpvTicketSeleccionada.Estado);

        UpdateContext({
            varEstadoSelected: Blank(),
            varGerenciaSelected: Blank(),
            varUpdateAreaSelected: Blank(),
            varUpdateSubAreaSelected: Blank(),
            varUpdatePaisSelected: Blank(),
            varUpdateSociedadSelected: Blank(),
            varUpdateAtendidoPorSelected: Blank(),
            varUpdateAnteriorNombreAtendidoPorSelected: Blank(),
            varUpdateAnteriorCorreoAtendidoPorSelected: Blank(),
            varUpdateMotivoDerivacionSelected: Blank()
        });
        UpdateContext({ Var_Ctx_ModalConfirmacion: false });
        UpdateContext({
            varOpenDropDownEstadoTransicion: false,
            varOpenDropDownGerencia: false,
            varOpenDropDownUpdateArea: false,
            varOpenDropDownUpdateSubArea: false,
            varOpenDropDownUpdateSociedad: false,
            varOpenDropDownUpdateAtendidoPor: false,
            varOpenDropDownUpdateMotivoDerivacion: false
        });

        Clear(colUpdateGerenciaSpv);
        Clear(colUpdateAreaSpv);
        Clear(colUpdateSubAreaSpv);
        Clear(colUpdatePaisSpv);
        Clear(colUpdateSociedadSpv);
        Clear(colUpdateAtendidoPorSpv);


        UpdateContext({ menuSelected: 3});


        ClearCollect(colTrackingTicketsSpv, Filter('LCP-001_List_TrackingTicketSolicitud', Codigo = Text(Var_SpvTicketSeleccionada.Codigo)));

        Clear(colDiscusionTicketSpv);
        ForAll(Filter(colTrackingTicketsSpv, Len(Trim(PlainText(Comentario))) > 0) As TrackingTicket,Collect(colDiscusionTicketSpv,{  Image: TrackingTicket.'Creado por'.Picture , UserName: TrackingTicket.'Creado por'.DisplayName , FechaCreado: TrackingTicket.FechaModificado , Comentario: TrackingTicket.Comentario }));
        /*
        ClearCollect(colDiscusionTicketSpv;{ Image: User().Image ; UserName: "Dmartin" ; FechaCreado: Now() ; Comentario : "Lorem ipsum dolor sit amet consectetur."};{ Image: User().Image ; UserName: "Ljuan" ; FechaCreado: Now() ; Comentario : "Lorem ipsum dolor sit amet consectetur."} );;
        */


        /*
        ClearCollect(colCambiosTicketSpv; { Image: User().Image ; UserName: "Dmartin" ; Fecha : Now() ; Accion: "Asignar" } ; { Image: User().Image ; UserName: "Ljuan" ; Fecha : Now() ; Accion: "Prioridad" }  ; { Image: User().Image ; UserName: "Ljuan" ; Fecha : Now() ; Accion: "Estado" ; Estado: "En proceso"});;
        */



        UpdateContext({  datosAdjuntos: 'LCP-001_Flow_ObtenerAdjuntos'.Run(Text(Var_SpvTicketSeleccionada.ID))  } );

        If(datosAdjuntos.response = "200", 

        Clear(colAdjuntosDetalleTicketSpv);
        ForAll(Table(ParseJSON(datosAdjuntos.datosadjuntos)), Collect(colAdjuntosDetalleTicketSpv,{  Nombre: Text(ThisRecord.Value.Nombre) , PesoBytes: Value(ThisRecord.Value.PesoBytes) , Url: Text(ThisRecord.Value.Url) }))

        );

        Set(
            varBytesExistentes,
            Sum(colAdjuntosDetalleTicketSpv, PesoBytes)
        );


        ClearCollect(colCambiosTicketSpv, colTrackingTicketsSpv );

        ClearCollect(colTransicionEstadoSpv, Switch(Text(Var_SpvTicketSeleccionada.Estado),Var_EstadosApp.EstadoEnRevision,[Var_EstadosApp.EstadoEnProceso, Var_EstadosApp.EstadoObservado, Var_EstadosApp.EstadoDerivado, Var_EstadosApp.EstadoCerrado],Var_EstadosApp.EstadoCerrado,[""],Var_EstadosApp.EstadoEnProceso,[Var_EstadosApp.EstadoResuelto, Var_EstadosApp.EstadoEnEsperaAprobacion,Var_EstadosApp.EstadoCerrado],Var_EstadosApp.EstadoRechazado,[""],Var_EstadosApp.EstadoObservado,[Var_EstadosApp.EstadoEnRevision,Var_EstadosApp.EstadoCerrado],Var_EstadosApp.EstadoEnEsperaAprobacion,[Var_EstadosApp.EstadoResuelto,Var_EstadosApp.EstadoCerrado],Var_EstadosApp.EstadoResuelto,[Var_EstadosApp.EstadoCerrado],Var_EstadosApp.EstadoDerivado,[""]));

        ClearCollect(
            colAreasSpv,
            [
                "Administración de personal",
                "Cobranzas",
                "Créditos BackOffice",
                "Cuentas por pagar",
                "Gestión comercial",
                "Nómina",
                "Nuevos servicios",
                "Seguros",
                "Tesorería operativa"
            ]
        )
        ;

        ClearCollect(colUsuarios,["JJulian","DMario"]);

        ClearCollect(colAsignarSLA, [3]);

        ClearCollect(colMotivoDerivacionSpv, ["Especialización técnica","Capacidad","Nivel de autorización","Error de asignación","Dependencia externa","Otro"]);

        // Campos desde la configuración del ticket

        // Paso 1: Guardamos el JSON crudo
        UpdateContext({
            Var_Ctx_ConfiguracionPaisSociedad: LookUp(
                'LCP-001_List_Configuracion_Ticket',
                Codigo = Text(Var_SpvTicketSeleccionada.ConfiguracionTicket),
                CabeceraPaisSociedad
            )
