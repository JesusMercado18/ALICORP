                                                                        HoverColor: =ColorValue(Var_ColorBlanco)
                                                                        HoverFill: =ColorValue(Var_ColorHoverBoton)
                                                                        OnSelect: "=//Se calcula el valor que toma el SLA del estado\r\n\r\n// LookUp('LCP-001_List_TicketSolicitudes';ID = Var_SpvTicketSeleccionada.ID);\r\n\r\nRefresh('LCP-001_List_TicketSolicitudes');\r\n\r\nIf(\r\n    IsEmpty(Filter('LCP-001_List_EstadosProceso',ConfiguracionTicket = Var_SpvTicketSeleccionada.ConfiguracionTicket)),\r\n    UpdateContext({Var_SLACalculado: 0, FechaVencimientoEstado: Var_SpvTicketSeleccionada.FechaVencimiento}),\r\n\r\n    If(\r\n    IsBlank(varEstadoSelected.Value),  \r\n    UpdateContext({ CloseAlert: true, Mensaje: \"Debes seleccionar un estado.\" }), \r\n        Switch(varEstadoSelected.Value,\r\n            //Caso Switch 1\r\n            Var_EstadosApp.EstadoObservado,\r\n                With(\r\n                {\r\n                    auxSLA: LookUp('LCP-001_List_EstadosProceso', EstadoActual = Var_EstadosApp.EstadoObservado && EstadoSiguiente = Var_EstadosApp.EstadoEnRevision).SLA\r\n                },\r\n                UpdateContext({Var_SLACalculado: If(Or(IsBlank(auxSLA), auxSLA = 0 ), 0, \r\n                If( Value(Spv_TxtAsignarSLATiempoAtencionDetalleTicket.Text) <>  auxSLA, Value(Spv_TxtAsignarSLATiempoAtencionDetalleTicket.Text), auxSLA))    });\r\n                If(\r\n                Var_SLACalculado = 0,\r\n                0, \r\n                // Calculamos la fecha de vencimiento del SLA para insertarlo en Tracking\r\n                ClearCollect( colFechas, AddColumns( Sequence(Var_SLACalculado * 3), Fecha, DateAdd(Now(), Value, TimeUnit.Days) ) ); \r\n                ClearCollect( colDiasHabiles, FirstN( Filter( colFechas, Weekday(Fecha, StartOfWeek.Monday) <= 5 && IsBlank( LookUp( colFeriados, FechaCompleta = Fecha ) ) ), Var_SLACalculado))\r\n                );\r\n                UpdateContext({FechaVencimientoEstado: If(Var_SLACalculado = 0 , Var_SpvTicketSeleccionada.FechaVencimiento, Last(colDiasHabiles).Fecha)})\r\n                ),\r\n\r\n            //Caso Switch 2\r\n            //1.Si no hay analista asignado -> No hay modificacion se encarga el balanceador\r\n            //2.Si hay analista seleccionado -> Busco el SLA en revisión \r\n            Var_EstadosApp.EstadoDerivado,\r\n                With(\r\n                {\r\n                    auxSLA: LookUp('LCP-001_List_EstadosProceso', EstadoActual = Var_EstadosApp.EstadoEnRevision && EstadoSiguiente = Blank()).SLA\r\n                },\r\n                UpdateContext({Var_SLACalculado: If(Or(IsBlank(auxSLA), auxSLA = 0 ), 0, auxSLA)});\r\n                If(\r\n                Var_SLACalculado = 0,\r\n                0, \r\n                // Calculamos la fecha de vencimiento del SLA para insertarlo en Tracking\r\n                ClearCollect( colFechas, AddColumns( Sequence(auxSLA * 3), Fecha, DateAdd(Now(), Value, TimeUnit.Days) ) ); \r\n                ClearCollect( colDiasHabiles, FirstN( Filter( colFechas, Weekday(Fecha, StartOfWeek.Monday) <= 5 && IsBlank( LookUp( colFeriados, FechaCompleta = Fecha ) ) ), auxSLA))\r\n                );\r\n                UpdateContext({FechaVencimientoEstado: If( Var_SLACalculado = 0, Var_SpvTicketSeleccionada.FechaVencimiento, Last(colDiasHabiles).Fecha)})\r\n                ),\r\n\r\n            //Caso Switch 3\r\n            Var_EstadosApp.EstadoEnProceso,\r\n                With(\r\n                {\r\n                    auxSLA: LookUp('LCP-001_List_EstadosProceso', EstadoActual = Var_EstadosApp.EstadoEnProceso && EstadoSiguiente = Blank()).SLA\r\n                },\r\n                UpdateContext({Var_SLACalculado: If(Or(IsBlank(auxSLA), auxSLA = 0 ), 0, auxSLA)});\r\n                If(\r\n                Var_SLACalculado = 0,\r\n                0, \r\n                // Calculamos la fecha de vencimiento del SLA para insertarlo en Tracking\r\n                ClearCollect( colFechas, AddColumns( Sequence(auxSLA * 3), Fecha, DateAdd(Now(), Value, TimeUnit.Days) ) ); \r\n                ClearCollect( colDiasHabiles, FirstN( Filter( colFechas, Weekday(Fecha, StartOfWeek.Monday) <= 5 && IsBlank( LookUp( colFeriados, FechaCompleta = Fecha ) ) ), auxSLA))\r\n                );\r\n                UpdateContext({FechaVencimientoEstado: If( Var_SLACalculado = 0, Var_SpvTicketSeleccionada.FechaVencimiento, Last(colDiasHabiles).Fecha)})\r\n                ),\r\n\r\n            //Caso Switch 4\r\n            Var_EstadosApp.EstadoEnEsperaAprobacion,\r\n                With(\r\n                {\r\n                    auxSLA: LookUp('LCP-001_List_EstadosProceso', EstadoActual = Var_EstadosApp.EstadoEnEsperaAprobacion && EstadoSiguiente = Var_EstadosApp.EstadoEnProceso).SLA\r\n                },\r\n                UpdateContext({Var_SLACalculado: If(Or(IsBlank(auxSLA), auxSLA = 0 ), 0, auxSLA)});\r\n                If(\r\n                Var_SLACalculado = 0,\r\n                0, \r\n                // Calculamos la fecha de vencimiento del SLA para insertarlo en Tracking\r\n                ClearCollect( colFechas, AddColumns( Sequence(auxSLA * 3), Fecha, DateAdd(Now(), Value, TimeUnit.Days) ) ); \r\n                ClearCollect( colDiasHabiles, FirstN( Filter( colFechas, Weekday(Fecha, StartOfWeek.Monday) <= 5 && IsBlank( LookUp( colFeriados, FechaCompleta = Fecha ) ) ), auxSLA))\r\n                );\r\n                UpdateContext({FechaVencimientoEstado: If( Var_SLACalculado = 0, Var_SpvTicketSeleccionada.FechaVencimiento, Last(colDiasHabiles).Fecha)})\r\n                ),\r\n\r\n            //Caso Switch 5\r\n            Var_EstadosApp.EstadoResuelto,\r\n                With(\r\n                {\r\n                    auxSLA: LookUp('LCP-001_List_EstadosProceso', EstadoActual = Var_EstadosApp.EstadoResuelto && EstadoSiguiente = Var_EstadosApp.EstadoCerrado).SLA\r\n                },\r\n\r\n                UpdateContext({Var_SLACalculado: If(Or(IsBlank(auxSLA), auxSLA = 0 ), 0, auxSLA)});\r\n                If(\r\n                Var_SLACalculado = 0,\r\n                0, \r\n                // Calculamos la fecha de vencimiento del SLA para insertarlo en Tracking\r\n                ClearCollect( colFechas, AddColumns( Sequence(auxSLA * 3), Fecha, DateAdd(Now(), Value, TimeUnit.Days) ) ); \r\n                ClearCollect( colDiasHabiles, FirstN( Filter( colFechas, Weekday(Fecha, StartOfWeek.Monday) <= 5 && IsBlank( LookUp( colFeriados, FechaCompleta = Fecha ) ) ), auxSLA))\r\n                );\r\n                UpdateContext({FechaVencimientoEstado: If( Var_SLACalculado = 0, Var_SpvTicketSeleccionada.FechaVencimiento, Last(colDiasHabiles).Fecha)})\r\n                ),\r\n            //Caso Switch\r\n            Var_EstadosApp.EstadoEnRevision,\r\n            true\r\n        )\r\n    )\r\n);\r\n\r\nIf(IsBlank(varEstadoSelected.Value),  UpdateContext({ CloseAlert: true, Mensaje: \"Debes seleccionar un estado.\" }), \r\n\r\nSwitch(varEstadoSelected.Value,\r\n\r\n    //Caso Switch 1\r\n    Var_EstadosApp.EstadoObservado,\r\n    If(\r\n        (varUpdateMotivoDerivacionSelected.Value = \"Otro\" && IsBlank(Trim(Spv_TxtOtroMotivoDerivacionDerivarDetalleTicket.Text))) || \r\n        IsBlank(varUpdateMotivoDerivacionSelected.Value),\r\n\r\n        UpdateContext({\r\n            CloseAlert: true,\r\n            Mensaje: If(IsBlank(varUpdateMotivoDerivacionSelected.Value), \"Debes seleccionar el motivo\", \"Debes ingresar el motivo de derivación.\")\r\n        }),\r\n\r\n        /* 2. SI LAS VALIDACIONES PASAN, PROCEDEMOS */\r\n        IfError(\r\n            Patch(\r\n                'LCP-001_List_TicketSolicitudes',\r\n                LookUp('LCP-001_List_TicketSolicitudes',ID = Var_SpvTicketSeleccionada.ID),\r\n                {\r\n                    EstadoActual: Var_EstadosApp.EstadoObservado,\r\n                    Motivo: Gbl_Confirmation_Update_5.ValorMotivo,\r\n                    MotivoObservacion: Gbl_Confirmation_Update_5.ValorMotivo,\r\n                    Comentario: Spv_RichComentariosDetalleTicket.HtmlText,\r\n                    FechaModificado: Now(),\r\n                    FechaVencimientoEstado: FechaVencimientoEstado,\r\n                    SLAEstado: Var_SLACalculado,\r\n                    Accionador: \"Supervisor\",\r\n                    Derivado: false,\r\n\r\n                    Evento: Var_EventoTrazabilidadApp.Estado\r\n\r\n                }\r\n            ),\r\n            /* 3. MANEJO DE ERRORES (Si el Patch falla) */\r\n            Set(_varError, {\r\n                Fecha: Now(),\r\n                Usuario: {\r\n                    Codigo: Var_ProfileUser.Codigo,\r\n                    Nombre: Var_ProfileUser.NombreApellido\r\n                },\r\n                CodigoTicket: Var_SpvTicketSeleccionada.Codigo,\r\n                Error: FirstError.Message,\r\n                Details: FirstError.Details,\r\n                Source: FirstError.Source,\r\n                Kind: FirstError.Kind\r\n            });\r\n            Patch('LCP-001_List_ErroresSolicitud', Defaults('LCP-001_List_ErroresSolicitud'), {\r\n                TipoSolicitud: Var_TipoOperacionApp.Actualizar,\r\n                FechaError: Now(),\r\n                Error: JSON(_varError, JSONFormat.Compact),\r\n                CodigoUsuario: Var_ProfileUser.Codigo\r\n            });\r\n            UpdateContext({ CloseAlert: true, Mensaje: \"Error al guardar: \" & FirstError.Message }),\r\n\r\n\r\n            /* 4. ÉXITO: CONTINUACIÓN SOLO SI NO HUBO ERROR */\r\n            If(\r\n                !IsEmpty(Var_uploadFile_listeAttachment),\r\n                'LCP-001_Flow_SubirAdjuntos'.Run(\r\n                    JSON(Var_uploadFile_listeAttachment),\r\n                    \"COMENTARIOS\",\r\n                    Text(Var_SpvTicketSeleccionada.ID)\r\n                )\r\n            );\r\n            UpdateContext({Var_Ctx_ModalConfirmacion: false});\r\n            Navigate(\r\n                Spv_Ticket,\r\n                ScreenTransition.Fade,\r\n                {\r\n                    AlertaSatisfactoria: true,\r\n                    MensajeSatisfactorio: \"Se actualizó el estado del ticket.\"\r\n                }\r\n            )\r\n        )\r\n    ),\r\n\r\n    //Caso Switch 2\r\n    Var_EstadosApp.EstadoDerivado,\r\n        UpdateContext(\r\n            {\r\n                Var_Ctx_ModalConfirmacion: true,\r\n                Var_Ctx_OperacionCatalogo: true,\r\n                Var_Ctx_DataModal: {\r\n                    Title: \"Derivar ticket\",\r\n                    SubTitle: \"Se procederá a derivar el ticket\",\r\n                    Menu: col_glbMotivosDerivar,\r\n                    Placeholder: \"Seleccione motivo de derivación\",\r\n                    ButtonOk: \"Sí, derivar\"\r\n                },\r\n                Var_Ctx_AccionEstado: Var_EstadosApp.EstadoDerivado\r\n            }\r\n        ),\r\n\r\n    //Caso Switch 3\r\n    Var_EstadosApp.EstadoEnProceso,\r\n\r\n        //EJEMPLO GUIA PARA CAMBIO DE APROBADORES CHECK\r\n        Switch(Var_SpvTicketSeleccionada.Estado,\r\n            //Caso Switch 1\r\n            Var_EstadosApp.EstadoEnEsperaAprobacion,\r\n                // 1. Creación de la colección con columna tipada para ordenamiento cronológico\r\n                ClearCollect(\r\n                    colAprobadoresCheck,\r\n                    AddColumns(\r\n                        ForAll(\r\n                            Table(ParseJSON(Trim(Var_SpvTicketSeleccionada.AprobadoresCheck))),\r\n                            {\r\n                                correo: Text(ThisRecord.Value.correo),\r\n                                nombre: Text(ThisRecord.Value.nombre),\r\n                                estado: Text(ThisRecord.Value.estado),\r\n                                fecha: Text(ThisRecord.Value.fecha)\r\n                            }\r\n                        ),\r\n                        FechaOrden,\r\n                        // Convertimos el texto a DateTime asumiendo un formato de fecha local. \r\n                        // Si la fecha viene vacía desde el JSON, asignamos Blank().\r\n                        If(IsBlank(fecha) Or Len(fecha) < 8, Blank(), DateTimeValue(fecha, \"es-ES\"))\r\n                    )\r\n                );\r\n                // 2. Aislamiento del registro y actualización estructurada\r\n                With(\r\n                    {\r\n                        varTargetRecord: First(\r\n                            Sort(\r\n                                Filter(\r\n                                    colAprobadoresCheck,\r\n                                    correo = Var_ProfileUser.CorreoUsuario && IsBlank(estado)\r\n                                ),\r\n                                FechaOrden,\r\n                                SortOrder.Descending\r\n                            )\r\n                        )\r\n                    },\r\n                    // 3. Verificamos que el registro haya sido encontrado antes de aplicar Patch\r\n                    If(\r\n                        !IsBlank(varTargetRecord.correo),\r\n                        Patch(\r\n                            colAprobadoresCheck,\r\n                            varTargetRecord,\r\n                            {\r\n                                estado: \"Aprobado\",\r\n                                fecha: Text(Now(), \"dd/mm/yyyy hh:mm:ss\")\r\n                            }\r\n\r\n                        );\r\n                        IfError(\r\n                            Patch(\r\n                                'LCP-001_List_TicketSolicitudes',\r\n                                LookUp('LCP-001_List_TicketSolicitudes',ID = Var_SpvTicketSeleccionada.ID),\r\n                                {\r\n                                    EstadoActual: Var_EstadosApp.EstadoEnProceso,\r\n                                    Comentario: Spv_RichComentariosDetalleTicket.HtmlText,\r\n                                    FechaModificado: Now(),\r\n                                    FechaVencimientoEstado: FechaVencimientoEstado,\r\n                                    SLAEstado: Var_SLACalculado,\r\n                                    Accionador: \"Supervisor\",\r\n                                    Evento: Var_EventoTrazabilidadApp.Estado,\r\n                                    Derivado: false, \r\n                                    Aprobacion: true,\r\n                                    AprobadoresCheck: JSON(colAprobadoresCheck,JSONFormat.Compact)\r\n                                }\r\n                            ),\r\n                            /* 3. MANEJO DE ERRORES (Si el Patch falla) */\r\n                            Set(_varError, {\r\n                                Fecha: Now(),\r\n                                Usuario: {\r\n                                    Codigo: Var_ProfileUser.Codigo,\r\n                                    Nombre: Var_ProfileUser.NombreApellido\r\n                                },\r\n                                CodigoTicket: Var_SpvTicketSeleccionada.Codigo,\r\n                                Error: FirstError.Message,\r\n                                Details: FirstError.Details,\r\n                                Source: FirstError.Source,\r\n                                Kind: FirstError.Kind\r\n                            });\r\n                            Patch('LCP-001_List_ErroresSolicitud', Defaults('LCP-001_List_ErroresSolicitud'), {\r\n                                TipoSolicitud: Var_TipoOperacionApp.Actualizar,\r\n                                FechaError: Now(),\r\n                                Error: JSON(_varError, JSONFormat.Compact),\r\n                                CodigoUsuario: Var_ProfileUser.Codigo\r\n                            });\r\n                            UpdateContext({ CloseAlert: true, Mensaje: \"Error al guardar: \" & FirstError.Message }),\r\n                            /* 4. ÉXITO: CONTINUACIÓN SOLO SI NO HUBO ERROR */\r\n                            If(\r\n                                !IsEmpty(Var_uploadFile_listeAttachment),\r\n                                'LCP-001_Flow_SubirAdjuntos'.Run(\r\n                                    JSON(Var_uploadFile_listeAttachment),\r\n                                    \"COMENTARIOS\",\r\n                                    Text(Var_SpvTicketSeleccionada.ID)\r\n                                )\r\n                            );\r\n                            UpdateContext({Var_Ctx_ModalConfirmacion: false});\r\n                            Navigate(\r\n                                Spv_Ticket,\r\n                                ScreenTransition.Fade,\r\n                                {\r\n                                    AlertaSatisfactoria: true,\r\n                                    MensajeSatisfactorio: \"Se actualizó el estado del ticket.\"\r\n                                }\r\n                            )\r\n                        ),\r\n                        UpdateContext({CloseAlert:true, Mensaje: \"Usted no es el aprobador asignado\"})\r\n                    )\r\n                ),\r\n            //Caso Switch 2\r\n            Var_EstadosApp.EstadoEnRevision,\r\n                With(\r\n                    {\r\n                        // 1. Sanitización de la cadena: Garantiza un arreglo JSON válido sin romper el esquema.\r\n                        SafeJSONString: If(\r\n                            IsBlank(Var_SpvTicketSeleccionada.AprobadoresCheck) Or Len(Trim(Var_SpvTicketSeleccionada.AprobadoresCheck)) < 2,\r\n                            \"[]\",\r\n                            Trim(Var_SpvTicketSeleccionada.AprobadoresCheck)\r\n                        )\r\n                    },\r\n                    // 2. Creación de la colección manteniendo la integridad de la columna 'Value' (UntypedObject)\r\n                    ClearCollect(\r\n                        colAprobadoresCheck,\r\n                        AddColumns(\r\n                            ForAll(\r\n                                // Al remover IfError, ForAll reconoce ThisRecord.Value correctamente\r\n                                Table(ParseJSON(SafeJSONString)),\r\n                                {\r\n                                    correo: Text(ThisRecord.Value.correo),\r\n                                    nombre: Text(ThisRecord.Value.nombre),\r\n                                    estado: Text(ThisRecord.Value.estado),\r\n                                    fecha: Text(ThisRecord.Value.fecha)\r\n                                }\r\n                            ),\r\n                            FechaOrden,\r\n                            // Convertimos el texto a DateTime asumiendo un formato de fecha local. \r\n                            If(\r\n                                IsBlank(fecha) Or Len(fecha) < 8, \r\n                                Blank(), \r\n                                DateTimeValue(fecha, \"es-ES\")\r\n                            )\r\n                        )\r\n                    )\r\n                );\r\n                // 2. Aislamiento del registro y actualización estructurada\r\n                With(\r\n                    {\r\n                        varTargetRecord: First(\r\n                            Sort(\r\n                                Filter(\r\n                                    colAprobadoresCheck,\r\n                                    correo = Var_ProfileUser.CorreoUsuario && IsBlank(estado)\r\n                                ),\r\n                                FechaOrden,\r\n                                SortOrder.Descending\r\n                            )\r\n                        )\r\n                    },\r\n                    // 3. Verificamos que el registro haya sido encontrado antes de aplicar Patch\r\n                    If(\r\n                        !IsBlank(varTargetRecord.correo),\r\n                        Patch(\r\n                            colAprobadoresCheck,\r\n                            varTargetRecord,\r\n                            {\r\n                                estado: \"En revisión\",\r\n                                fecha: Text(Now(), \"dd/mm/yyyy hh:mm:ss\")\r\n                            }\r\n\r\n                        );\r\n                        IfError(\r\n                            Patch(\r\n                                'LCP-001_List_TicketSolicitudes',\r\n                                LookUp('LCP-001_List_TicketSolicitudes',ID = Var_SpvTicketSeleccionada.ID),\r\n                                {\r\n                                    EstadoActual: Var_EstadosApp.EstadoEnProceso,\r\n                                    Comentario: Spv_RichComentariosDetalleTicket.HtmlText,\r\n                                    FechaModificado: Now(),\r\n                                    FechaVencimientoEstado: FechaVencimientoEstado,\r\n                                    SLAEstado: Var_SLACalculado,\r\n                                    Accionador: \"Supervisor\",\r\n                                    Evento: Var_EventoTrazabilidadApp.Estado\r\n                                }\r\n                            ),\r\n                            /* 3. MANEJO DE ERRORES (Si el Patch falla) */\r\n                            Set(_varError, {\r\n                                Fecha: Now(),\r\n                                Usuario: {\r\n                                    Codigo: Var_ProfileUser.Codigo,\r\n                                    Nombre: Var_ProfileUser.NombreApellido\r\n                                },\r\n                                CodigoTicket: Var_SpvTicketSeleccionada.Codigo,\r\n                                Error: FirstError.Message,\r\n                                Details: FirstError.Details,\r\n                                Source: FirstError.Source,\r\n                                Kind: FirstError.Kind\r\n                            });\r\n                            Patch('LCP-001