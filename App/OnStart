//----Flujo para consultar el Rol del usuario----
Set(Var_EmailUser;"test@alicorp.pe");;
Set(Var_ProfileUser; LookUp('LCP-001_List_Usuarios'; CorreoUsuario = Var_EmailUser) );;
ClearCollect(
    colRolesUsuario;
    ForAll(
        ParseJSON(Var_ProfileUser.RolSistema);
        {
            Rol: Text(ThisRecord.Rol)
        }
    )
);;
Set(
    Var_RolSistema;
    LookUp(
        colRolesUsuario;
        Rol = "Analista"
    )
);;
