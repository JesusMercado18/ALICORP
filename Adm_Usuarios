  Adm_Usuarios:
    Properties:
      Fill: =ColorValue(Var_ColorFondoLateral)
      LoadingSpinnerColor: =RGBA(0, 120, 212, 1)
      OnVisible: |-
        =//----Variables-----
        UpdateContext({menuSelected: 7});
        UpdateContext({Var_Ctx_MostrarItems : false });
        //----Flujo----
        Set(Var_GridPageSizeAdmUsuarios, 5);
        Set(Var_ResponseAdmUsuarios,
            'LCP-001_Flow_AdmPaginacionUsuarios'.Run(
                Var_GridPageSizeAdmUsuarios,
                0,
                Concat(
                    Filter(colQuerysAdmUsuarios, mark),
                    query,
                    " and "
                ),
                "NEXT"
            )
        );
        //----Variables respuesta flujo----
        Set(TotalItemAdmUsuarios, Value(ParseJSON(Var_ResponseAdmUsuarios.totalitems)));
        Set(Var_DataAdmUsuarios, Table(ParseJSON(Var_ResponseAdmUsuarios.response)));
        //----Datos para llenar galeria de comunicados----
        Clear(objGalleryDataAdmUsuarios);
        ForAll(
            FirstN(Var_DataAdmUsuarios,Var_GridPageSizeAdmUsuarios),
            Collect(
                objGalleryDataAdmUsuarios,
                {
                    ID:                ThisRecord.Value.ID,
                    Codigo:            ThisRecord.Value.Codigo,
                    Nombre:            ThisRecord.Value.Nombre,
                    Apellido:          ThisRecord.Value.Apellido,
                    CorreoUsuario:     ThisRecord.Value.CorreoUsuario,
                    RolSistema:        ThisRecord.Value.RolSistema,
                    EstadoSistema:     ThisRecord.Value.EstadoSistema,
                    Estado:            ThisRecord.Value.Estado,
                    Gerencia:          ThisRecord.Value.Gerencia,
                    RolPerfil:         ThisRecord.Value.RolPerfil,
                    Vicepresidencia:   ThisRecord.Value.Vicepresidencia,
                    Direccion:         ThisRecord.Value.Direccion,
                    Area:              ThisRecord.Value.Area,
                    Pais:              ThisRecord.Value.Pais,
                    Sociedad:          ThisRecord.Value.Sociedad,
                    NombreJefeDirecto: ThisRecord.Value.NombreJefeDirecto,
                    CorreoJefeDirecto: ThisRecord.Value.CorreoJefeDirecto
                }
            )
        );
        //----Guardamos el primer ID REAL de todo el dataset----
        Set(Var_FirstIDAdmUsuarios, Min(objGalleryDataAdmUsuarios, ID));
        //----Control real de NEXT (Top + 1)----
        Set(Var_HasPrevAdmUsuarios, false);
        Set(Var_HasNextAdmUsuarios, CountRows(Var_DataAdmUsuarios) > Var_GridPageSizeAdmUsuarios);
        Set(Var_CurrentPageAdmUsuarios, 1);
